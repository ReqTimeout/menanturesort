---
import '../styles/global.css';
import siteData from '../data/site.json';
import { buildSEO } from '../lib/seo';
import OrganizationSchema from '../components/seo/OrganizationSchema.astro';
import ProductSchema from '../components/seo/ProductSchema.astro';
import ScrollProgress from '../components/svelte/ScrollProgress.svelte';
import SmoothScroll from '../components/svelte/SmoothScroll.svelte';
import ScrollEffects from '../components/svelte/ScrollEffects.svelte';
import StickyMobileCTA from '../components/svelte/StickyMobileCTA.svelte';
import StockToast from '../components/svelte/StockToast.svelte';
import AnalyticsBoot from '../components/astro/AnalyticsBoot.astro';
import MonitorBoot from '../components/svelte/MonitorBoot.svelte';
import WhatsAppFloating from '../components/astro/WhatsAppFloating.astro';
import LeadForm from '../components/svelte/LeadForm.svelte';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
  noindex?: boolean;
  bodyClass?: string;
}

const seo = buildSEO({
  title: Astro.props.title,
  description: Astro.props.description,
  image: Astro.props.image,
  canonical: Astro.props.canonical,
  type: Astro.props.type,
  publishedTime: Astro.props.publishedTime,
  author: Astro.props.author,
  noindex: Astro.props.noindex,
});
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0D1B14" />
  <meta name="generator" content={Astro.generator} />
  <!-- Google Search Console Verification -->
  <meta name="google-site-verification" content="d-7Ysdp2HpFgntspeuC4-jsiy_cvgq3LxNVubodaYyU" />

  <!-- Primary Meta -->
  <title>{seo.title}</title>
  <meta name="title" content={seo.title} />
  <meta name="description" content={seo.description} />
  <link rel="canonical" href={seo.canonical} />
  {seo.noindex && <meta name="robots" content="noindex,nofollow" />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={seo.openGraph.type} />
  <meta property="og:url" content={seo.openGraph.url} />
  <meta property="og:title" content={seo.openGraph.title} />
  <meta property="og:description" content={seo.openGraph.description} />
  <meta property="og:site_name" content={seo.openGraph.siteName} />
  <meta property="og:locale" content={seo.openGraph.locale} />
  {seo.openGraph.publishedTime && <meta property="article:published_time" content={seo.openGraph.publishedTime} />}
  {seo.openGraph.authors && <meta property="article:author" content={seo.openGraph.authors[0]} />}
  {seo.openGraph.images.map(img => (
    <Fragment>
      <meta property="og:image" content={img.url} />
      <meta property="og:image:width" content={img.width.toString()} />
      <meta property="og:image:height" content={img.height.toString()} />
      <meta property="og:image:alt" content={img.alt} />
    </Fragment>
  ))}

  <!-- Twitter -->
  <meta name="twitter:card" content={seo.twitter.card} />
  <meta name="twitter:url" content={seo.openGraph.url} />
  <meta name="twitter:title" content={seo.twitter.title} />
  <meta name="twitter:description" content={seo.twitter.description} />
  {seo.twitter.images.map(img => <meta name="twitter:image" content={img} />)}

  <!-- Preconnect (V5.2) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Preload critical fonts for faster LCP -->
  <!-- Fonts: Plus Jakarta Sans (display alt) + Fraunces (modern serif) + Inter (body) + JetBrains Mono (numbers) -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" /></noscript>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
  <link rel="preconnect" href="https://wa.me" />

  <!-- Schema.org -->
  <OrganizationSchema data={siteData} />
  <ProductSchema />
  <!-- Analytics is now loaded via AnalyticsBoot.astro component (handles gtag_report_conversion, enhanced conversions, global WA click interceptor) -->
</head>
<body class={Astro.props.bodyClass}>
  <!-- V5.3 WOW factors -->
  <ScrollProgress client:load />
  <SmoothScroll client:load />
  <ScrollEffects client:load />
  <StickyMobileCTA client:load />
  <StockToast client:load />


  <slot />

  <!-- Global WhatsApp floating button (all pages) -->
  <WhatsAppFloating />

  <!-- Sticky lead form modal trigger — appears after 30s idle -->
  <LeadForm client:only="svelte" />

  <!-- Global site script (minimal) -->
  <script is:inline>
    // Smooth scroll untuk anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        const href = this.getAttribute('href');
        if (href === '#' || href.length < 2) return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          const offset = 80;
          const targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
          window.scrollTo({ top: targetPosition, behavior: 'smooth' });
        }
      });
    });
  </script>
  <AnalyticsBoot />
  <MonitorBoot client:idle />
</body>
</html>
