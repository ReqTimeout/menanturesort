---
/**
 * /kontak — V5.2 rewrite (PageHero + Contact + Bank + 4 Steps)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import PageHero from '../components/astro/PageHero.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import Pattern from '../components/astro/Pattern.astro';
import SectionBackground from '../components/astro/SectionBackground.astro';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { MessageCircle, Phone, Mail, MapPin, Instagram, Shield, Building2, ArrowRight, MessageSquare } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'kontak');
const waUtama = waUrl(siteData.contact.whatsapp, 'Halo, saya ingin konsultasi investasi vila', 'kontak_main');
---

<BaseLayout title="Kontak & Konsultasi Gratis — Menantu Resort" description="Hubungi tim sales Menantu Resort. WhatsApp responsif, konsultasi gratis tanpa komitmen. Rekening resmi BNI/BCA/BSI a.n. PT Cipta Multikarya Propertindo.">
  <NavMenu client:load />

  <main class="pt-20">
    <PageHero
      eyebrow="Hubungi Kami"
      title="Konsultasi Gratis,"
      accent="Tanpa Komitmen."
      description="Tim sales kami siap memandu dari pertanyaan pertama hingga akad. WhatsApp responsif di jam kerja."
      primaryCta={{ text: 'Chat WhatsApp Sekarang', href: waUtama }}
      stats={[
        { value: '< 1 jam', label: 'Respon WA' },
        { value: '24/7', label: 'Online' },
        { value: '100%', label: 'Gratis' },
      ]}
      bgColor="cream"
    />

    <SectionDivider variant="diamond" />

    <!-- Contact + Bank -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade" data-section="info">
      <SectionBackground variant="cream" pattern={true} orbs={true} intensity="subtle" />
      <Pattern variant="dots" color="gold" opacity={0.05} />
      <div class="container-wide relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          <article class="card-premium p-10">
            <h2 class="font-display text-2xl text-forest-700 mb-6">Informasi Kontak</h2>
            <div class="space-y-6">
              <div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mb-2 font-mono">WhatsApp</div>
                <a href={waUtama} target="_blank" rel="noopener" class="font-display text-2xl text-forest-700 font-bold hover:text-gold-700 transition">{siteData.contact.whatsappDisplay}</a>
                <p class="text-sm text-ink-soft mt-1">Responsif 09:00 - 21:00 WIB setiap hari</p>
              </div>
              <div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mb-2 font-mono">Email</div>
                <a href={`mailto:${siteData.contact.email}`} class="text-lg text-forest-700 hover:text-gold-700 transition">{siteData.contact.email}</a>
              </div>
              <div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mb-2 font-mono">Alamat</div>
                <p class="text-base text-ink-700">{siteData.contact.address}</p>
              </div>
              <div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mb-2 font-mono">Instagram</div>
                <a href={`https://instagram.com/${siteData.social.instagram.replace('@','')}`} target="_blank" rel="noopener" class="text-forest-700 hover:text-gold-700 transition">{siteData.social.instagram}</a>
              </div>
            </div>
          </article>

          <article class="card-premium p-10 bg-forest-50">
            <div class="flex items-center gap-2 mb-4">
              <Building2 size={20} class="text-gold-700" />
              <h2 class="font-display text-2xl text-forest-700">Rekening Resmi</h2>
            </div>
            <p class="text-sm text-ink-soft mb-6">
              Salin nomor rekening di bawah ini untuk transfer. Konfirmasi via WhatsApp setelah pembayaran.
            </p>
            <div class="space-y-3">
              {siteData.bankAccounts.map((bank) => (
                <div class="bg-white p-4 border border-cream-100">
                  <div class="flex items-center justify-between mb-1">
                    <div class="font-bold text-forest-700 text-lg">{bank.bank}</div>
                    <button type="button" class="text-xs text-gold-700 hover:underline" onclick={`navigator.clipboard.writeText('${bank.number.replace(/\s/g, '')}')`}>Copy</button>
                  </div>
                  <div class="font-mono text-base">{bank.number}</div>
                  <div class="text-xs text-ink-soft mt-1">a.n. {bank.name}</div>
                </div>
              ))}
            </div>
          </article>
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- 4 Steps -->
    <section class="relative section-cream py-20 md:py-32 gsap-fade" data-section="steps">
      <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
      <Pattern variant="grid" color="forest" opacity={0.04} />
      <div class="container-wide relative">
        <!-- Centered premium header -->
        <div class="text-center max-w-3xl mx-auto mb-14 md:mb-20">
          <div class="inline-flex items-center gap-3 mb-5">
            <span class="h-px w-10 bg-gradient-to-r from-transparent to-gold-500"></span>
            <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-gold-700 font-semibold">— Proses</span>
            <span class="h-px w-10 bg-gradient-to-l from-transparent to-gold-500"></span>
          </div>
          <h2 class="font-display text-display-lg text-forest-700 leading-[1.0] tracking-tight mb-5">
            4 langkah <em class="text-gold-700 italic">simpel</em>
          </h2>
          <p class="font-body text-base sm:text-lg text-ink-soft leading-relaxed max-w-2xl mx-auto">
            Dari konsultasi pertama hingga SHM di tangan — mudah, transparan, <span class="text-forest-700 font-semibold">tidak ada hidden cost</span>.
          </p>
        </div>

        <!-- Steps with connecting line + numbered cards -->
        <div class="relative max-w-6xl mx-auto">
          <!-- Connecting line (desktop only) -->
          <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-gold-500/40 to-transparent pointer-events-none" aria-hidden="true"></div>

          <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-4">
            {[
              { n: '01', title: 'Chat WhatsApp', desc: 'Konsultasi awal gratis, pilih tipe villa sesuai budget', icon: MessageCircle, cta: 'Mulai Chat' },
              { n: '02', title: 'Booking Fee', desc: 'Rp 10 juta refundable 30 hari — lock harga 90 hari', icon: Shield, cta: 'Lock Unit' },
              { n: '03', title: 'Survei Lokasi', desc: 'Gratis shuttle dari Bandung, termasuk akomodasi', icon: MapPin, cta: 'Jadwalkan' },
              { n: '04', title: 'Akad Notaris', desc: 'SHM atas nama pribadi, serah terima unit ready', icon: Building2, cta: 'Akad' },
            ].map((s, i) => {
              const Icon = s.icon;
              return (
                <div class="group relative">
                  <!-- Big number watermark -->
                  <div class="absolute -top-2 -left-1 font-display text-[5rem] sm:text-[6rem] font-bold text-forest-700/[0.04] leading-none pointer-events-none select-none" aria-hidden="true">
                    {s.n}
                  </div>

                  <!-- Card -->
                  <div class="relative card-premium p-6 sm:p-7 text-center h-full flex flex-col items-center hover:border-gold-500/60 hover:-translate-y-1 transition-all duration-300">
                    <!-- Icon with gold ring -->
                    <div class="relative mb-4">
                      <div class="absolute inset-0 bg-gold-500/20 blur-xl rounded-full scale-110 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                      <div class="relative w-16 h-16 sm:w-20 sm:h-20 bg-gradient-to-br from-forest-700 to-forest-800 text-gold-500 flex items-center justify-center ring-2 ring-gold-500/30 group-hover:ring-gold-500 group-hover:scale-105 transition-all duration-300">
                        <Icon size={26} strokeWidth="1.75" />
                      </div>
                    </div>

                    <div class="font-mono text-[10px] uppercase tracking-[0.25em] text-gold-700 font-bold mb-2">
                      Step {s.n}
                    </div>
                    <h3 class="font-display text-lg sm:text-xl text-forest-700 font-bold leading-tight mb-2">
                      {s.title}
                    </h3>
                    <p class="text-[13px] sm:text-sm text-ink-soft leading-relaxed flex-grow">
                      {s.desc}
                    </p>

                    <!-- Step connector dot (desktop only) -->
                    <div class="hidden md:block absolute -right-2 top-1/2 -translate-y-1/2 w-3 h-3 bg-gold-500 rotate-45 ring-4 ring-cream-50" aria-hidden="true"></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Bottom CTA -->
        <div class="text-center mt-12 md:mt-16">
          <div class="inline-flex flex-col items-center gap-4">
            <a href={waUtama} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg shadow-xl shadow-whatsapp/20 hover:shadow-whatsapp/40 transition-shadow">
              <MessageCircle class="w-4 h-4" />
              Mulai Step 01 — Chat Sekarang
              <ArrowRight class="w-4 h-4" />
            </a>
            <p class="text-[11px] font-mono uppercase tracking-widest text-ink-mute">
              Rata-rata waktu total · <span class="text-forest-700 font-semibold">30–45 hari</span> · Tanpa hidden cost
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
