---
/**
 * /lokasi — V5.3 rewrite (storytelling + animated bg)
 *
 * Sections:
 *   1. PageHero (forest cream)
 *   2. Narrative — kenapa Bandung Timur?
 *   3. Map (Google Maps embed)
 *   4. Akses 6 kota
 *   5. Nearby 8 destinasi
 *   6. Final CTA
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import PageHero from '../components/astro/PageHero.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import SectionBackground from '../components/astro/SectionBackground.astro';
import { waUrl } from '../lib/utils';
import { MessageCircle, MapPin, Mountain, TreePine, Waves, Train, Car, Hospital, Camera, ArrowRight, Clock, MapPinned, Sparkles } from 'lucide-svelte';
import siteData from '../data/site.json';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'lokasi');

const akses = [
  { from: 'Bandung Kota', time: '45 menit', route: 'Lewat Tol Cileunyi — fully paved highway', icon: Car },
  { from: 'Jakarta', time: '2.5 jam', route: 'Tol Cipularang → Cileunyi exit', icon: Car },
  { from: 'Sumedang', time: '40 menit', route: 'Jalan Nasional via Tanjungsari', icon: Car },
  { from: 'Garut', time: '1 jam', route: 'Lewat Nagreg — scenic route', icon: Car },
  { from: 'Stasiun Cicalengka', time: '8 menit', route: 'Akses langsung KAI Commuter Line', icon: Train },
  { from: 'Bandara Kertajati', time: '1.5 jam', route: 'Tol Cisumdawu — direct access', icon: MapPinned },
];

const nearby = [
  { name: 'Curug Cinulang', desc: 'Air terjun 50m signature, 5 menit — photo spot favorit tamu', icon: Waves, distance: '5 min' },
  { name: 'Gunung Masigit', desc: 'Hiking trail pemula, sunrise point, 20 menit', icon: Mountain, distance: '20 min' },
  { name: 'Bukit Teletubbies', desc: 'Bukit hijau ikonik, 15 menit — viral di Instagram', icon: TreePine, distance: '15 min' },
  { name: 'Cicalengka Dreamland', desc: 'Family waterpark + outbound, 10 menit', icon: Camera, distance: '10 min' },
  { name: 'Stasiun Cicalengka', desc: 'Akses KAI, 8 menit — commuter line ready', icon: Train, distance: '8 min' },
  { name: 'Gerbang Tol Cileunyi', desc: '45 menit ke pusat Kota Bandung', icon: Car, distance: '45 min' },
  { name: 'RSUD Cicalengka', desc: 'Rumah sakit tipe C — 12 menit', icon: Hospital, distance: '12 min' },
  { name: 'Taman Renang Nagreg', desc: 'Pemandian air panas alami, 25 menit', icon: Waves, distance: '25 min' },
];
---

<BaseLayout
  title="Lokasi Strategis Bandung Timur — 45 Menit dari Tol Cileunyi | Menantu Resort"
  description="Menantu Resort di Cicalengka, Bandung Timur. 45 menit dari Tol Cileunyi, 8 menit dari Stasiun KAI. Udara sejuk pegunungan, view 360° perbukitan hijau, dikelilingi 8 destinasi wisata populer. Hidden gem yang mulai viral di kalangan investor smart."
>
  <NavMenu client:load />

  <main class="pt-20">
    <PageHero
      eyebrow="Lokasi Strategis"
      title="Hidden Gem Bandung Timur,"
      accent="45 Menit dari Tol Cileunyi."
      description="Bayangkan memiliki villa resort di udara sejuk 1.000 mdpl — tapi masih 45 menit dari pusat Kota Bandung. Dekat 8 destinasi wisata viral, 8 menit dari KAI, 1.5 jam dari Bandara Kertajati. Lokasi yang sempurna untuk investasi villa produktif."
      primaryCta={{ text: 'Chat Survey Lokasi', href: waLink('Halo, saya ingin survey lokasi Menantu Resort. Bisa dijadwalkan?') }}
      secondaryCta={{ text: 'Lihat Villa', href: '/villa' }}
      stats={[
        { value: '45 min', label: 'Tol Cileunyi' },
        { value: '8 min', label: 'Stasiun KA' },
        { value: '1.5 jam', label: 'Bandara Kertajati' },
      ]}
      image="/images/hero/hero-aerial-1280.jpg"
      imageAlt="Curug Cinulang — air terjun signature dekat Menantu Resort"
      imageBadge="5 Menit dari Resort"
    />

    <SectionDivider variant="diamond" />

    <!-- Narrative — Why Bandung Timur? -->
    <section class="relative bg-cream-50 py-20 md:py-32 gsap-fade" data-section="why-lokasi">
      <SectionBackground variant="cream" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-16">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— Why This Location</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-6">
              Bandung Timur punya <em class="text-gold-700">3 keunggulan</em> yang tidak dimiliki Lembang atau Dago.
            </h2>
            <p class="font-body text-lg text-ink-soft max-w-3xl leading-relaxed">
              Lembang dan Dago sudah overtourism — macet, harga tanah selangit, okupansi menurun. Bandung Timur (Cicalengka, Nagreg) adalah frontier berikutnya. Udara lebih sejuk, view lebih hijau, dan harga masih 30-40% lebih rendah. Saatnya masuk sebelum harga mengikuti.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="card-premium p-8 relative overflow-hidden group hover:scale-[1.02] transition-transform">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gold-500/10 rounded-full blur-2xl"></div>
            <div class="relative">
              <div class="font-mono text-4xl text-gold-500 mb-3 font-bold">01</div>
              <h3 class="font-display text-2xl text-forest-700 mb-3">Udara Lebih Sejuk</h3>
              <p class="text-ink-soft leading-relaxed">1.000 mdpl — suhu 18-24°C year-round. Tamu resort Anda betah berlibur lebih lama = revenue lebih tinggi.</p>
            </div>
          </div>
          <div class="card-premium p-8 relative overflow-hidden group hover:scale-[1.02] transition-transform">
            <div class="absolute top-0 right-0 w-32 h-32 bg-forest-700/10 rounded-full blur-2xl"></div>
            <div class="relative">
              <div class="font-mono text-4xl text-gold-500 mb-3 font-bold">02</div>
              <h3 class="font-display text-2xl text-forest-700 mb-3">Akses 45 Menit</h3>
              <p class="text-ink-soft leading-relaxed">Dekat Tol Cileunyi — 45 menit dari Kota Bandung, 2.5 jam dari Jakarta. Tamu weekend tidak ragu datang.</p>
            </div>
          </div>
          <div class="card-premium p-8 relative overflow-hidden group hover:scale-[1.02] transition-transform">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gold-500/10 rounded-full blur-2xl"></div>
            <div class="relative">
              <div class="font-mono text-4xl text-gold-500 mb-3 font-bold">03</div>
              <h3 class="font-display text-2xl text-forest-700 mb-3">8 Destinasi Viral</h3>
              <p class="text-ink-soft leading-relaxed">Curug Cinulang, Bukit Teletubbies, Gunung Masigit — magnet tamu. Okupansi tinggi sepanjang tahun.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- Map -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade" data-section="map">
      <SectionBackground variant="forest" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— Peta Lokasi</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-4">
              Temukan <em class="text-gold-700">kami</em> di peta
            </h2>
            <p class="text-ink-soft text-lg max-w-2xl">Cicalengka, Bandung Timur — Jawa Barat. Buka Google Maps untuk rute detail dari lokasi Anda.</p>
          </div>
        </div>

        <div class="card-premium overflow-hidden aspect-[16/9] md:aspect-[21/9] shadow-2xl">
          <iframe src={siteData.contact.mapsEmbed} width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Lokasi Menantu Resort"></iframe>
        </div>
        <div class="flex items-center justify-center gap-2 mt-6 text-base text-ink-700 font-medium">
          <MapPin size={18} class="text-gold-700" />
          {siteData.contact.address}
        </div>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- Akses 6 kota -->
    <section class="relative section-cream py-20 md:py-32 gsap-fade" data-section="akses">
      <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— Akses dari Kota</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-4">
              Dari mana saja, <em class="text-gold-700">dekat & strategis</em>
            </h2>
            <p class="text-ink-soft text-lg max-w-2xl">6 kota besar terhubung langsung. Tamu Anda tidak perlu ragu soal akses.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {akses.map((a) => {
            const Icon = a.icon;
            return (
              <div class="card-premium p-7 group hover:scale-[1.02] transition-all duration-300 hover:shadow-2xl">
                <div class="flex items-start justify-between mb-4">
                  <div class="w-12 h-12 bg-forest-700 text-gold-500 flex items-center justify-center">
                    <Icon size={22} />
                  </div>
                  <span class="badge badge-gold text-sm font-bold">{a.time}</span>
                </div>
                <h3 class="font-display text-xl text-forest-700 mb-2 font-bold">{a.from}</h3>
                <p class="text-sm text-ink-soft leading-relaxed">{a.route}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- Nearby 8 destinasi -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade" data-section="nearby">
      <SectionBackground variant="cream" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— Sekitar Resort</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-4">
              Bandung Timur <em class="text-gold-700">punya segalanya</em>
            </h2>
            <p class="text-ink-soft text-lg max-w-2xl">8 destinasi wisata populer dalam radius 25 menit. Magnet tamu yang akan membuat villa Anda selalu booked.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
          {nearby.map((n) => {
            const Icon = n.icon;
            return (
              <div class="card-premium p-6 hover:scale-[1.02] transition-transform duration-300 group">
                <div class="flex items-center justify-between mb-4">
                  <div class="w-12 h-12 bg-forest-700 text-gold-500 flex items-center justify-center group-hover:bg-gold-500 group-hover:text-forest-700 transition-colors">
                    <Icon size={20} />
                  </div>
                  <span class="font-mono text-xs text-gold-700 font-bold uppercase tracking-wider">{n.distance}</span>
                </div>
                <h3 class="font-display text-lg text-forest-700 mb-2 font-bold leading-tight">{n.name}</h3>
                <p class="text-sm text-ink-soft leading-relaxed">{n.desc}</p>
              </div>
            );
          })}
        </div>

        <div class="mt-12 p-8 bg-forest-700 text-cream-50 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/10 rounded-full blur-3xl pointer-events-none"></div>
          <div class="relative grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
            <div class="md:col-span-2">
              <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-2 font-semibold">— Pro Tip</div>
              <h3 class="font-display text-2xl text-cream-50 mb-2">Tamu resort = repeat customer</h3>
              <p class="text-cream-50/80 leading-relaxed">Dengan 8 destinasi viral di sekitar, tamu resort Anda punya alasan kuat untuk <em class="text-gold-500">kembali setiap bulan</em>. Okupansi rata-rata resort bintang 5 di area ini: 65-75%.</p>
            </div>
            <div class="text-center md:text-right">
              <div class="font-display text-5xl text-gold-500 font-bold">65-75%</div>
              <div class="text-cream-50/70 text-sm uppercase tracking-wider">Avg. Occupancy</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- Final CTA -->
    <section class="relative bg-forest-900 text-cream-50 py-20 md:py-32 overflow-hidden gsap-fade" data-section="cta">
      <SectionBackground variant="dark" pattern={true} orbs={true} intensity="strong" />
      <div class="container-wide relative text-center">
        <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-4 font-semibold">— Limited Slots</div>
        <h2 class="font-display text-display-md text-cream-50 leading-[0.95] tracking-tight mb-6 max-w-3xl mx-auto">
          Lihat langsung <em class="text-gold-500">lokasinya</em>
        </h2>
        <p class="font-body text-lg text-cream-50/80 max-w-2xl mx-auto mb-10 leading-relaxed">
          Survey lokasi setiap Sabtu — gratis, tidak ada komitmen, tidak ada tekanan. Tim kami akan antar keliling kawasan, tunjukkan 8 destinasi, dan jelaskan kenapa ini adalah <em>timing terbaik</em> untuk masuk.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={waLink('Halo, saya mau jadwalkan survey lokasi Menantu Resort. Saya pilih hari Sabtu.')} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle size={18} /> Jadwalkan Survey Gratis
          </a>
          <a href="/villa" class="btn btn-outline btn-lg">Lihat 3 Tipe Villa <ArrowRight class="w-4 h-4" /></a>
        </div>
        <p class="mt-8 text-sm text-cream-50/60">
          ⚡ <strong>Promo Survey:</strong> 50 pendaftar pertama dapat souvenir eksklusif Sahid Hotels.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
