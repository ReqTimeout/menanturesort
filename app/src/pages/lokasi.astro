---
/**
 * /lokasi — V5.2 rewrite (PageHero + Map + Akses + Nearby)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import PageHero from '../components/astro/PageHero.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import Pattern from '../components/astro/Pattern.astro';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { MessageCircle, MapPin, Mountain, TreePine, Waves, Train, Car, Hospital, Camera, ArrowRight } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'lokasi');

const akses = [
  { from: 'Bandung Kota', time: '45 menit', route: 'Tol Cileunyi → Cicalengka' },
  { from: 'Jakarta', time: '2.5 jam', route: 'Tol Cipularang → Cileunyi' },
  { from: 'Sumedang', time: '40 menit', route: 'Jalan Nasional' },
  { from: 'Garut', time: '1 jam', route: 'Lewat Nagreg' },
  { from: 'Stasiun Cicalengka', time: '8 menit', route: 'Akses langsung KAI' },
  { from: 'Bandara Kertajati', time: '1.5 jam', route: 'Tol Cisumdawu' },
];

const nearby = [
  { name: 'Curug Cinulang', desc: 'Air terjun signature, 5 menit', icon: Waves },
  { name: 'Gunung Masigit', desc: 'Destinasi gunung, 20 menit', icon: Mountain },
  { name: 'Bukit Teletubbies', desc: 'Bukit ikonik, 15 menit', icon: TreePine },
  { name: 'Cicalengka Dreamland', desc: 'Wisata keluarga, 10 menit', icon: Camera },
  { name: 'Stasiun Cicalengka', desc: 'Akses KAI, 8 menit', icon: Train },
  { name: 'Gerbang Tol Cileunyi', desc: '45 menit ke Bandung', icon: Car },
  { name: 'RSUD Cicalengka', desc: 'Rumah sakit terdekat', icon: Hospital },
  { name: 'Taman Renang Nagreg', desc: 'Wisata air, 25 menit', icon: Waves },
];
---

<BaseLayout
  title="Lokasi Strategis — Hidden Gem Bandung Timur | Menantu Resort"
  description="Menantu Resort di Cicalengka, Bandung Timur. 45 menit dari Tol Cileunyi. Udara sejuk pegunungan, view 360° perbukitan hijau, akses mudah dari kota besar."
>
  <NavMenu client:load />

  <main class="pt-20">
    <PageHero
      eyebrow="Lokasi Strategis"
      title="Hidden Gem Bandung Timur,"
      accent="45 Menit dari Tol Cileunyi."
      description="Udara sejuk pegunungan, view 360° perbukitan hijau, akses mudah dari kota besar — tanpa keramaian overtourism."
      primaryCta={{ text: 'Chat Survey Lokasi', href: waLink('Halo, saya ingin survey lokasi Menantu Resort.') }}
      secondaryCta={{ text: 'Lihat Villa', href: '/villa' }}
      stats={[
        { value: '45 min', label: 'Tol Cileunyi' },
        { value: '8 min', label: 'Stasiun KA' },
        { value: '1.5 jam', label: 'Bandara Kertajati' },
      ]}
      image="/images/hero/hero-aerial-1280.jpg"
      imageAlt="Curug Cinulang — air terjun signature dekat Menantu Resort"
      imageBadge="5 Menit dari Resort"
    />

    <SectionDivider variant="diamond" />

    <!-- Map -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade" data-section="map">
      <Pattern variant="dots" color="forest" opacity={0.03} />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— Peta</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight">
              Temukan <em class="text-gold-700">kami</em>
            </h2>
          </div>
        </div>

        <div class="card-premium overflow-hidden aspect-[16/9] md:aspect-[21/9]">
          <iframe src={siteData.contact.mapsEmbed} width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Lokasi Menantu Resort"></iframe>
        </div>
        <div class="flex items-center justify-center gap-2 mt-4 text-sm text-ink-500">
          <MapPin size={16} class="text-gold-700" />
          {siteData.contact.address}
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- Akses -->
    <section class="relative section-cream py-20 md:py-32 gsap-fade" data-section="akses">
      <Pattern variant="grid" color="forest" opacity={0.04} />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— Akses</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight">
              Dari mana saja, <em class="text-gold-700">dekat & strategis</em>
            </h2>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {akses.map((a) => (
            <div class="card-premium p-6">
              <div class="flex items-start justify-between mb-2">
                <div class="font-display text-lg text-forest-700 font-semibold">{a.from}</div>
                <span class="badge badge-gold">{a.time}</span>
              </div>
              <p class="text-sm text-ink-soft">{a.route}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- Nearby -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade" data-section="nearby">
      <Pattern variant="dots-dense" color="gold" opacity={0.05} />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— Sekitar</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight">
              Bandung Timur <em class="text-gold-700">punya segalanya</em>
            </h2>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {nearby.map((n) => {
            const Icon = n.icon;
            return (
              <div class="card-premium p-6 hover:scale-[1.02] transition-transform">
                <div class="w-12 h-12 bg-forest-700 text-gold-500 flex items-center justify-center mb-3">
                  <Icon size={20} />
                </div>
                <h3 class="font-display text-lg text-forest-700 mb-1">{n.name}</h3>
                <p class="text-sm text-ink-soft">{n.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- Final CTA -->
    <section class="relative bg-forest-900 text-cream-50 py-20 md:py-32 overflow-hidden gsap-fade" data-section="cta">
      <Pattern variant="gold-sparkle" color="gold" opacity={0.06} />
      <div class="container-wide relative text-center">
        <h2 class="font-display text-display-md text-cream-50 leading-[0.95] tracking-tight mb-6">
          Lihat langsung <em class="text-gold-500">lokasinya</em>
        </h2>
        <p class="font-body text-lg text-cream-50/80 max-w-2xl mx-auto mb-8">
          Tim kami siap antar survey — gratis, tidak ada komitmen.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={waLink('Halo, saya mau jadwalkan survey lokasi')} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle size={18} /> Jadwalkan Survey
          </a>
          <a href="/villa" class="btn btn-outline btn-lg">Lihat Tipe Villa <ArrowRight class="w-4 h-4" /></a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
