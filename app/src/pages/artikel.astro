---
/**
 * /artikel — V5.5 (pagination 12/page, 147 articles = 13 pages)
 * Page 1: featured + 11 grid + paginate
 * Page 2+: 12 grid + paginate
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import SectionBackground from '../components/astro/SectionBackground.astro';
import articles from '../data/articles.json';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { ArrowRight, Calendar, MessageCircle, TrendingUp, BookOpen, Sparkles, Award, ChevronLeft, ChevronRight, Filter } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'artikel');
const PER_PAGE = 12;
const CURRENT_PAGE = 1;
const TOTAL_PAGES = Math.ceil(articles.length / PER_PAGE);

// Sort: highest-intent "harga" first, then by date desc
const sortedArticles = [...articles].sort((a, b) => {
  if (a.slug.includes('harga-simulasi')) return -1;
  if (b.slug.includes('harga-simulasi')) return 1;
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});

// Get all unique categories for filter
const allCategories = [...new Set(sortedArticles.map(a => a.cat))].sort();

// Page 1: featured = article[0], grid = article[1..12] (11 items)
const featured = sortedArticles[0];
const grid = sortedArticles.slice(1, PER_PAGE);

// Pagination helpers
const pageHref = (p) => p === 1 ? '/artikel/' : `/artikel/page/${p}/`;
const prevPage = null; // page 1 has no prev
const nextPage = TOTAL_PAGES > 1 ? 2 : null;

// Build numbered page list (1, 2, 3 ... total)
const pageNumbers = Array.from({ length: TOTAL_PAGES }, (_, i) => i + 1);
---

<BaseLayout
  title="Insight & Artikel Investasi Villa Bandung — Menantu Resort"
  description="Insight properti, simulasi KPR, dan review jujur investasi villa di Bandung Timur. 147+ artikel transparan, tanpa jargon sales, murni data & pengalaman operator 50 tahun."
  canonical="https://menantu-resort.com/artikel/"
>
  <NavMenu client:load />

  <main>
    <!-- HERO -->
    <section class="relative bg-forest-700 text-cream-50 overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">
      <SectionBackground variant="forest" pattern={true} orbs={true} intensity="medium" />
      <div class="container-wide relative">
        <div class="max-w-4xl">
          <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-5 font-bold flex items-center gap-2">
            <BookOpen size={14} /> Insight · Edukasi · Transparansi
          </div>
          <h1 class="font-display text-4xl md:text-6xl lg:text-7xl text-cream-50 leading-[0.95] tracking-tight mb-6">
            Baca <em class="text-gold-500">cerdas</em> sebelum<br class="hidden md:block" />
            <em class="text-gold-500">beli</em> villa investasi.
          </h1>
          <p class="font-body text-lg md:text-xl text-cream-50/85 leading-relaxed max-w-2xl mb-8">
            Simulasi KPR, review jujur kompetitor, analisis yield, dan strategi ROI — tanpa jargon sales, murni data & pengalaman operator 50 tahun.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href={waLink('Halo, saya mau konsultasi gratis via WhatsApp setelah baca artikel.')} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
              <MessageCircle size={18} /> Konsultasi Gratis
            </a>
            <a href="#articles" class="btn btn-outline-light btn-lg">
              Mulai Baca <ArrowRight size={16} />
            </a>
          </div>

          <!-- Trust strip -->
          <div class="mt-10 pt-7 border-t border-gold-500/20 flex flex-wrap items-center gap-x-7 gap-y-2 text-xs font-mono text-cream-50/70">
            <span class="inline-flex items-center gap-1.5"><Sparkles size={12} class="text-gold-500" /> {articles.length} artikel</span>
            <span class="inline-flex items-center gap-1.5"><Award size={12} class="text-gold-500" /> Tim MK LAND + Sahid</span>
            <span class="inline-flex items-center gap-1.5"><TrendingUp size={12} class="text-gold-500" /> Update mingguan</span>
            <span class="inline-flex items-center gap-1.5"><Filter size={12} class="text-gold-500" /> {allCategories.length} kategori</span>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- FEATURED -->
    {featured && (
      <section class="bg-cream-50 relative" id="articles">
        <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
        <div class="container-wide py-14 md:py-20 relative">
          <div class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-gold-700 mb-5 font-bold">
            <Sparkles size={14} /> Paling Diminati · Paling Dicari
          </div>

          <a href={`/artikel/${featured.slug}/`} class="group block card-premium overflow-hidden grid grid-cols-1 lg:grid-cols-2 bg-white hover:border-gold-500 transition-colors">
            <div class="relative aspect-[16/10] lg:aspect-auto overflow-hidden bg-forest-700">
              <img src={featured.image} alt={featured.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="eager" width="800" height="500" />
              <div class="absolute top-4 left-4 flex gap-2">
                <span class="badge badge-gold text-[10px] uppercase tracking-wider font-bold">Featured</span>
                <span class="badge badge-gold text-[10px] uppercase tracking-wider font-bold">{featured.cat}</span>
              </div>
            </div>
            <div class="p-7 md:p-10 lg:p-12 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-3 text-xs text-ink-mute font-mono">
                <Calendar size={12} />
                <span>{featured.date}</span>
                <span>·</span>
                <span>{featured.readTime}</span>
              </div>
              <h2 class="font-display text-xl md:text-3xl lg:text-4xl text-forest-700 font-bold leading-[1.1] mb-3 group-hover:text-gold-700 transition-colors">
                {featured.title}
              </h2>
              <p class="text-ink-700 text-sm md:text-base leading-relaxed mb-5">
                {featured.excerpt}
              </p>
              <div class="flex items-center gap-2 text-gold-700 font-bold uppercase tracking-wider text-sm group-hover:gap-3 transition-all">
                Baca Versi Lengkap
                <ArrowRight size={16} />
              </div>
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- GRID + PAGINATION -->
    <section class="bg-cream-50 relative">
      <div class="container-wide pb-16 md:pb-24 relative">
        <div class="flex flex-wrap items-end justify-between gap-3 mb-8">
          <div>
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-2 font-semibold">— Insight Lengkap</div>
            <h2 class="font-display text-2xl md:text-4xl text-forest-700 font-bold leading-tight">
              Semua <em class="text-gold-700">Artikel</em>
            </h2>
          </div>
          <div class="font-mono text-xs text-ink-mute uppercase tracking-wider">
            Halaman {CURRENT_PAGE} dari {TOTAL_PAGES} · {articles.length} artikel total
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-7">
          {grid.map((p) => (
            <a
              href={`/artikel/${p.slug}/`}
              class="card-premium group overflow-hidden flex flex-col h-full hover:shadow-2xl transition-shadow"
            >
              <div class="relative aspect-[16/10] overflow-hidden bg-forest-700">
                <img src={p.image} alt={p.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" width="640" height="400" />
                <div class="absolute inset-0 bg-gradient-to-t from-forest-900/40 via-transparent to-transparent"></div>
                <div class="absolute top-3 left-3">
                  <span class="badge badge-gold text-[10px] uppercase tracking-wider font-bold">{p.cat}</span>
                </div>
                <div class="absolute top-3 right-3">
                  <span class="px-2 py-1 bg-forest-900/80 backdrop-blur text-cream-50 text-[10px] font-mono uppercase tracking-wider">{p.readTime}</span>
                </div>
              </div>
              <div class="p-5 md:p-6 flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2.5 text-[11px] text-ink-mute font-mono">
                  <Calendar size={10} />
                  <span>{p.date}</span>
                </div>
                <h3 class="font-display text-base md:text-lg text-forest-700 font-bold mb-2.5 group-hover:text-gold-700 transition-colors leading-snug line-clamp-3">
                  {p.title}
                </h3>
                <p class="text-sm text-ink-soft leading-relaxed mb-4 flex-1 line-clamp-3">{p.excerpt}</p>
                <div class="flex items-center justify-between mt-auto pt-3 border-t border-cream-100">
                  <span class="text-[11px] text-gold-700 font-bold uppercase tracking-wider">{p.highlight}</span>
                  <span class="text-gold-700 text-xs font-bold inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
                    Baca <ArrowRight size={12} />
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- PAGINATION -->
        <nav class="mt-14 md:mt-20" aria-label="Pagination">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-5">
            <div class="font-mono text-[11px] text-ink-mute uppercase tracking-wider order-2 sm:order-1">
              Menampilkan 1-{grid.length} dari {articles.length}
            </div>
            <div class="flex items-center gap-1.5 order-1 sm:order-2 flex-wrap justify-center">
              {prevPage && (
                <a href={pageHref(prevPage)} class="inline-flex items-center gap-1 px-3 py-2 bg-white border border-cream-100 hover:border-gold-500 text-ink-700 text-sm font-mono uppercase tracking-wider transition-colors">
                  <ChevronLeft size={14} /> Prev
                </a>
              )}
              {pageNumbers.map((p) => (
                <a
                  href={pageHref(p)}
                  class={`min-w-[40px] h-10 inline-flex items-center justify-center text-sm font-mono font-bold transition-colors ${
                    p === CURRENT_PAGE
                      ? 'bg-forest-700 text-gold-500 border border-forest-700'
                      : 'bg-white border border-cream-100 text-ink-700 hover:border-gold-500 hover:text-gold-700'
                  }`}
                  aria-current={p === CURRENT_PAGE ? 'page' : undefined}
                >
                  {p}
                </a>
              ))}
              {nextPage && (
                <a href={pageHref(nextPage)} class="inline-flex items-center gap-1 px-3 py-2 bg-white border border-cream-100 hover:border-gold-500 text-ink-700 text-sm font-mono uppercase tracking-wider transition-colors">
                  Next <ChevronRight size={14} />
                </a>
              )}
            </div>
          </div>
        </nav>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- SUBSCRIBE CTA -->
    <section class="relative section-cream py-20 md:py-32 gsap-fade" data-section="subscribe">
      <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-4 font-semibold">— Weekly Update</div>
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-6">
              Update <em class="text-gold-700">mingguan</em> via WhatsApp
            </h2>
            <p class="font-body text-lg text-ink-soft leading-relaxed mb-6">
              Dapatkan artikel baru + data properti Bandung + promo spesial langsung di WhatsApp Anda. <strong class="text-forest-700">100% gratis, unsubscribe kapan saja</strong>.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3"><Sparkles size={18} class="text-gold-700 flex-shrink-0 mt-0.5" /><span class="text-ink-700">1 artikel baru setiap Jumat</span></li>
              <li class="flex items-start gap-3"><Sparkles size={18} class="text-gold-700 flex-shrink-0 mt-0.5" /><span class="text-ink-700">Data pasar properti bulanan</span></li>
              <li class="flex items-start gap-3"><Sparkles size={18} class="text-gold-700 flex-shrink-0 mt-0.5" /><span class="text-ink-700">Promo eksklusif subscriber</span></li>
            </ul>
            <a
              href={waLink('Halo, saya mau subscribe update artikel mingguan via WhatsApp.')}
              target="_blank"
              rel="noopener"
              class="btn btn-whatsapp btn-lg"
            >
              <MessageCircle size={18} /> Subscribe via WhatsApp <ArrowRight size={16} />
            </a>
          </div>
          <div class="card-premium p-10 bg-forest-700 text-cream-50 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/10 rounded-full blur-3xl"></div>
            <div class="relative">
              <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-3 font-semibold">— Sample Article Preview</div>
              <div class="font-display text-2xl text-cream-50 mb-4 leading-tight">"ROI 10% Guarantee: Realita atau Marketing?"</div>
              <p class="text-cream-50/80 text-sm leading-relaxed mb-6">
                <em>Bedah akad ROI guarantee — apa yang dijamin, apa yang tidak. Tanpa selling, murni transparansi...</em>
              </p>
              <div class="border-t border-gold-500/30 pt-4 flex items-center justify-between text-xs">
                <span class="font-mono text-cream-50/60">5 Juni 2026 · 5 min read</span>
                <span class="text-gold-500 font-bold uppercase tracking-wider">Most Read</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
