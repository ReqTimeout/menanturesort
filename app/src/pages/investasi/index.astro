---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/astro/Navbar.astro';
import Footer from '../../components/astro/Footer.astro';
import WhatsAppFloating from '../../components/astro/WhatsAppFloating.astro';
import KprCalculator from '../../components/svelte/KprCalculator.svelte';
import siteData from '../../data/site.json';
import villaData from '../../data/villa.json';
import { formatShort, waUrl } from '../../lib/utils';
import { ArrowRight, MessageCircle, Building2, TrendingUp, Users, Shield, Check } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'investasi_overview');
const scenarios = villaData.types.map((v) => ({
  ...v,
  surplus: v.passiveIncome - v.cicilanBank,
}));
---
<BaseLayout
  title="Skema Investasi & Passive Income"
  description="Cicilan villa Anda, ditutup income villa. Dua skema KPR: Bank (5% tenor 20thn) atau Developer (7% tanpa BI Checking). ROI 10% guarantee."
>
  <Navbar />
  <main class="pt-20">
    <section class="section section-cream">
      <div class="container-tight text-center">
        <span class="eyebrow">Investment Hub</span>
        <h1 class="heading-title mt-4 mb-6">
          Cicilan Anda, <br/><em>Ditutup Income Anda.</em>
        </h1>
        <p class="text-body-lg text-ink-500 max-w-2xl mx-auto">
          Dua skema pembayaran — pilih yang sesuai profil Anda.
          Semua tipe villa dirancang agar passive income menutup cicilan, dengan surplus.
        </p>
      </div>
    </section>

    <section class="section-tight section-white">
      <div class="container-tight">
        <KprCalculator client:visible />
      </div>
    </section>

    <section class="section section-cream">
      <div class="container-tight">
        <div class="text-center mb-12">
          <span class="eyebrow">2 Skema Pembiayaan</span>
          <h2 class="heading-title mt-4">Pilih Jalur <em>Anda.</em></h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <article class="card accent-line p-10">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 bg-forest-500 text-gold-500 flex items-center justify-center">
                <Building2 size="20" />
              </div>
              <span class="badge badge-gold">Tenor Panjang</span>
            </div>
            <h3 class="heading text-2xl mb-2">KPR Bank</h3>
            <p class="text-sm text-ink-700 mb-6">Bunga flat 5% · Tenor 15-20 tahun · Wajib BI Checking</p>
            <ul class="space-y-2 text-sm text-ink-500 mb-8">
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Bunga lebih rendah</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Tenor hingga 20 tahun</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> DP mulai 30%</li>
            </ul>
            <a href="/investasi/skema-bank" class="btn btn-primary w-full">Detail Skema KPR Bank</a>
          </article>

          <article class="card accent-line p-10 border-2 border-gold-500">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 bg-gold-500 text-forest-700 flex items-center justify-center">
                <Users size="20" />
              </div>
              <span class="badge badge-gold">Tanpa BI Checking</span>
            </div>
            <h3 class="heading text-2xl mb-2">KPR Developer</h3>
            <p class="text-sm text-ink-700 mb-6">Bunga flat 7% · Tenor 15 tahun · Approval 7 hari</p>
            <ul class="space-y-2 text-sm text-ink-500 mb-8">
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Tanpa BI Checking</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Approval lebih cepat</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> DP lebih ringan (25%)</li>
            </ul>
            <a href="/investasi/skema-developer" class="btn btn-primary w-full">Detail Skema KPR Developer</a>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-white">
      <div class="container-tight">
        <div class="text-center mb-12">
          <span class="eyebrow">Perbandingan Semua Vila</span>
          <h2 class="heading-title mt-4">Cicilan vs <em>Passive Income.</em></h2>
        </div>
        <div class="overflow-x-auto card p-6 md:p-10">
          <table class="w-full text-left min-w-[640px]">
            <thead>
              <tr class="border-b-2 border-forest-500 text-xs uppercase tracking-wider text-ink-700">
                <th class="py-4 pr-4 font-semibold">Tipe Vila</th>
                <th class="py-4 pr-4 font-semibold">Harga</th>
                <th class="py-4 pr-4 font-semibold">DP 30%</th>
                <th class="py-4 pr-4 font-semibold">Cicilan</th>
                <th class="py-4 pr-4 font-semibold">Income</th>
                <th class="py-4 font-semibold">Surplus</th>
              </tr>
            </thead>
            <tbody>
              {scenarios.map((s) => (
                <tr class="border-b border-cream-100 last:border-0 hover:bg-cream-50 transition">
                  <td class="py-4 pr-4 font-semibold text-forest-700">
                    {s.name} {s.bestValue && <span class="badge badge-gold text-xs ml-2">Best</span>}
                  </td>
                  <td class="py-4 pr-4 font-mono text-sm">{s.priceDisplay}</td>
                  <td class="py-4 pr-4 text-sm text-ink-500">{formatShort(s.dpBank)}</td>
                  <td class="py-4 pr-4 font-mono text-sm">{formatShort(s.cicilanBank)}</td>
                  <td class="py-4 pr-4 font-mono text-sm text-forest-500 font-semibold">{formatShort(s.passiveIncome)}</td>
                  <td class="py-4 font-mono text-sm text-success font-semibold">+{formatShort(s.surplus)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container-tight">
        <div class="text-center mb-12">
          <span class="eyebrow">3 Pilar</span>
          <h2 class="heading-title mt-4">Kenapa <em>Passive Income Konsisten?</em></h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <article class="card p-10 text-center">
            <Shield size="32" class="text-gold-700 mx-auto mb-4" />
            <h3 class="heading text-xl mb-3">Sahid Operasional</h3>
            <p class="text-body text-ink-500">Dikelola harian oleh tim Sahid Hotel & Resort — standar hospitality bintang 5, okupansi terjaga.</p>
          </article>
          <article class="card p-10 text-center">
            <TrendingUp size="32" class="text-gold-700 mx-auto mb-4" />
            <h3 class="heading text-xl mb-3">ROI Guarantee 10%</h3>
            <p class="text-body text-ink-500">Jaminan minimal 10% per tahun untuk 2 tahun pertama — melindungi cashflow awal.</p>
          </article>
          <article class="card p-10 text-center">
            <Users size="32" class="text-gold-700 mx-auto mb-4" />
            <h3 class="heading text-xl mb-3">Bagi Hasil 70-30</h3>
            <p class="text-body text-ink-500">70% untuk pemilik, 30% untuk operasional. Transparan, dikirim bulanan ke rekening Anda.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-cream-dark relative overflow-hidden">
      <div class="absolute inset-0 pattern-dots opacity-30"></div>
      <div class="container-tight relative text-center">
        <div class="inline-flex items-center gap-2 bg-gold-500/15 text-gold-700 px-4 py-2 mb-6">
          <span class="w-2 h-2 bg-gold-500 rounded-full animate-pulse-gold"></span>
          <span class="text-xs font-semibold uppercase tracking-widest">Hanya 16 Unit Tersisa</span>
        </div>
        <h2 class="heading-title mb-6">Booking Fee <em class="text-gold-700">Rp 10 Juta.</em></h2>
        <p class="text-body-lg text-ink-500 max-w-2xl mx-auto mb-8">
          Lock harga, refundable 30 hari. Amankan unit favorit sebelum fase berikutnya.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={waLink('Halo, saya ingin booking')} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle size="18" /> Booking via WhatsApp
          </a>
          <a href="/villa" class="btn btn-outline btn-lg">Lihat Tipe Villa</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloating />
</BaseLayout>
