---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/astro/Navbar.astro';
import Footer from '../../components/astro/Footer.astro';
import WhatsAppFloating from '../../components/astro/WhatsAppFloating.astro';
import siteData from '../../data/site.json';
import { formatRupiah, formatShort, waUrl } from '../../lib/format';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'investasi');
const ctaWa = waLink('Halo, saya tertarik dengan skema ini');
---
<BaseLayout
  title="KPR Developer — Tanpa BI Checking"
  description="KPR Developer villa Menantu Resort: bunga flat 7%, tenor 15 tahun, tanpa BI Checking, approval 7 hari. Cocok untuk first-time investor."
>
  <Navbar />
  <main>
    <section class="relative bg-gradient-to-br from-secondary to-primary-dark text-white py-3xl overflow-hidden">
      <div class="absolute inset-0 pattern-subtle opacity-20"></div>
      <div class="container relative z-10">
        <div class="max-w-3xl">
          <a href="/investasi" class="text-white text-sm hover:underline">← Kembali ke Investment Hub</a>
          <span class="eyebrow text-white mt-md">Skema Pembiayaan</span>
          <h1 class="heading-display text-white mb-md">
            KPR Developer — <br/><span class="text-white italic">Tanpa BI Checking, Approval 7 Hari.</span>
          </h1>
          <p class="text-body-lg text-white/85 mb-xl">
            Bunga flat 7% per tahun, tenor 15 tahun, tanpa BI Checking. Solusi untuk Anda
            yang belum punya track record kredit atau butuh approval cepat.
          </p>
          <a href={ctaWa} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">💬 Konsultasi KPR Developer</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-xl mb-2xl">
          <div class="card p-xl text-center">
            <div class="text-sm text-ink-mute uppercase tracking-wider mb-xs">Bunga</div>
            <div class="text-4xl font-display font-bold text-primary">7%</div>
            <div class="text-sm text-ink-soft">flat per tahun</div>
          </div>
          <div class="card p-xl text-center">
            <div class="text-sm text-ink-mute uppercase tracking-wider mb-xs">Tenor</div>
            <div class="text-4xl font-display font-bold text-primary">15</div>
            <div class="text-sm text-ink-soft">tahun</div>
          </div>
          <div class="card p-xl text-center">
            <div class="text-sm text-ink-mute uppercase tracking-wider mb-xs">Approval</div>
            <div class="text-4xl font-display font-bold text-primary">≤ 7</div>
            <div class="text-sm text-ink-soft">hari kerja</div>
          </div>
        </div>

        <div class="card p-2xl mb-2xl border-2 border-secondary">
          <span class="badge badge-gold mb-md">KEUNGGULAN UTAMA</span>
          <h2 class="heading-2 mb-lg">Tanpa BI Checking</h2>
          <p class="text-body-lg text-ink-soft mb-lg">
            Cocok untuk freelancer, wiraswasta baru, atau profesional yang belum pernah
            punya histori kredit. Prosesnya lebih manusiawi dan personal.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
            <div>
              <h4 class="heading-3 mb-sm">✓ Yang Diperlukan</h4>
              <ul class="space-y-xs text-sm">
                <li>• KTP & NPWP</li>
                <li>• Bukti penghasilan 3 bulan terakhir</li>
                <li>• Rekening koran 3 bulan</li>
                <li>• Down payment 25-30%</li>
              </ul>
            </div>
            <div>
              <h4 class="heading-3 mb-sm">⚡ Yang Didapat</h4>
              <ul class="space-y-xs text-sm">
                <li>• Approval dalam 7 hari kerja</li>
                <li>• Akad notaris yang jelas & terikat</li>
                <li>• Tidak ada penalti pelunasan awal</li>
                <li>• Asuransi jiwa built-in</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="card p-2xl">
          <h2 class="heading-2 mb-lg">Simulasi Cicilan KPR Developer</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[640px]">
              <thead>
                <tr class="border-b-2 border-primary text-sm uppercase tracking-wider text-ink-mute">
                  <th class="py-md pr-md font-semibold">Tipe Villa</th>
                  <th class="py-md pr-md font-semibold">DP 25%</th>
                  <th class="py-md pr-md font-semibold">Pokok Pinjaman</th>
                  <th class="py-md pr-md font-semibold">Cicilan / Bln (15 thn)</th>
                  <th class="py-md font-semibold">Total Bayar</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-ink-mute/20"><td class="py-md pr-md font-semibold">Menantu Bijak</td><td class="py-md pr-md">Rp 300jt</td><td class="py-md pr-md">Rp 900jt</td><td class="py-md pr-md">Rp 9,1jt</td><td class="py-md">Rp 1,64 M</td></tr>
                <tr class="border-b border-ink-mute/20"><td class="py-md pr-md font-semibold">Menantu Idaman</td><td class="py-md pr-md">Rp 400jt</td><td class="py-md pr-md">Rp 1,2 M</td><td class="py-md pr-md">Rp 11,4jt</td><td class="py-md">Rp 2,05 M</td></tr>
                <tr class="border-b border-ink-mute/20"><td class="py-md pr-md font-semibold">Menantu Mapan</td><td class="py-md pr-md">Rp 500jt</td><td class="py-md pr-md">Rp 1,5 M</td><td class="py-md pr-md">Rp 14,8jt</td><td class="py-md">Rp 2,66 M</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-ink-mute mt-md">* Simulasi bunga flat 7% p.a., DP 25%. Tenor hingga 15 tahun.</p>
        </div>
      </div>
    </section>

    <section class="section bg-accent">
      <div class="container text-center">
        <h2 class="heading-display mb-md">Belum Punya BI Checking Lancar?</h2>
        <p class="text-body-lg text-ink-soft mb-xl max-w-2xl mx-auto">
          KPR Developer dirancang untuk Anda. Tim kami akan memandu dari konsultasi
          hingga akad di notaris.
        </p>
        <a href={ctaWa} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">💬 Mulai Proses KPR Developer</a>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloating />
</BaseLayout>
