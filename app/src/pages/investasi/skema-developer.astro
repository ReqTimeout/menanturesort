---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/astro/Navbar.astro';
import Footer from '../../components/astro/Footer.astro';
import WhatsAppFloating from '../../components/astro/WhatsAppFloating.astro';
import siteData from '../../data/site.json';
import { waUrl } from '../../lib/utils';
import { MessageCircle, Check, ArrowLeft } from 'lucide-svelte';
const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'kpr_bank');
---
<BaseLayout title="KPR Developer — Bunga 7% Tenor 20 Tahun" description="KPR Developer villa Menantu Resort: bunga flat 7%, tenor 15 tahun, DP mulai 30%. Syarat, dokumen, simulasi cicilan.">
  <Navbar />
  <main class="pt-20">
    <section class="section section-cream">
      <div class="container-tight">
        <a href="/investasi" class="text-forest-500 text-sm hover:text-gold-700 inline-flex items-center gap-1 mb-4">
          <ArrowLeft size="14" /> Kembali
        </a>
        <span class="eyebrow text-forest-500 block mb-3">Skema Pembiayaan</span>
        <h1 class="heading-title mb-6">KPR Developer — <em>Tanpa BI Checking, Approval 7 Hari.</em></h1>
        <p class="text-body-lg text-ink-500 max-w-2xl">Bunga flat 7% per tahun, tenor 15 tahun, tanpa BI Checking. Solusi untuk Anda yang butuh approval cepat.</p>
      </div>
    </section>

    <section class="section-tight section-white">
      <div class="container-tight">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="card accent-line p-8 text-center">
            <div class="text-xs text-ink-700 uppercase tracking-wider mb-2">Bunga</div>
            <div class="font-display text-5xl text-forest-500 font-bold mb-1">7%</div>
            <div class="text-sm text-ink-700">flat per tahun</div>
          </div>
          <div class="card accent-line p-8 text-center">
            <div class="text-xs text-ink-700 uppercase tracking-wider mb-2">Tenor</div>
            <div class="font-display text-5xl text-forest-500 font-bold mb-1">15</div>
            <div class="text-sm text-ink-700">tahun</div>
          </div>
          <div class="card accent-line p-8 text-center">
            <div class="text-xs text-ink-700 uppercase tracking-wider mb-2">DP Minimum</div>
            <div class="font-display text-5xl text-forest-500 font-bold mb-1">30%</div>
            <div class="text-sm text-ink-700">dari harga jual</div>
          </div>
        </div>

        <div class="card p-8 md:p-12 mb-12">
          <h2 class="heading text-2xl mb-6">Simulasi Cicilan (DP 25%)</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-left min-w-[640px]">
              <thead>
                <tr class="border-b-2 border-forest-500 text-xs uppercase tracking-wider text-ink-700">
                  <th class="py-3 pr-4">Tipe Vila</th>
                  <th class="py-3 pr-4">DP 30%</th>
                  <th class="py-3 pr-4">Pokok</th>
                  <th class="py-3 pr-4">Cicilan 15thn</th>
                  <th class="py-3">Cicilan 20thn</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-cream-100"><td class="py-4 pr-4 font-semibold">Bijak</td><td class="py-4 pr-4">Rp 300jt</td><td class="py-4 pr-4">Rp 900jt</td><td class="py-4 pr-4" colspan="2">Rp 9,1jt / bulan</td></tr>
                <tr class="border-b border-cream-100"><td class="py-4 pr-4 font-semibold">Idaman</td><td class="py-4 pr-4">Rp 400jt</td><td class="py-4 pr-4">Rp 1,2M</td><td class="py-4 pr-4" colspan="2">Rp 11,4jt / bulan</td></tr>
                <tr class="border-b border-cream-100"><td class="py-4 pr-4 font-semibold">Mapan</td><td class="py-4 pr-4">Rp 500jt</td><td class="py-4 pr-4">Rp 1,5M</td><td class="py-4 pr-4" colspan="2">Rp 14,8jt / bulan</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="card p-8">
            <h3 class="heading text-xl mb-4">Syarat Pengajuan</h3>
            <ul class="space-y-2 text-sm text-ink-500">
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> WNI, usia 21-55 tahun</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Penghasilan min Rp 15jt/bulan</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Tanpa BI Checking</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Approval 7 hari kerja</li>
            </ul>
          </div>
          <div class="card p-8">
            <h3 class="heading text-xl mb-4">Dokumen</h3>
            <ul class="space-y-2 text-sm text-ink-500">
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> KTP, KK, Akta Nikah</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Slip gaji 3 bulan / SPT</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> Rekening koran 3-6 bulan</li>
              <li class="flex gap-2"><Check size="16" class="text-gold-700 flex-shrink-0 mt-0.5" /> NPWP pribadi</li>
            </ul>
          </div>
        </div>

        <div class="text-center mt-12">
          <a href={waLink('Halo, saya tertarik KPR Developer')} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle size="18" /> Mulai Konsultasi
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloating />
</BaseLayout>
