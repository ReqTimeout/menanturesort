---
/**
 * /artikel/[slug] — Single article page
 * Real content, SEO-friendly, with CTA to WhatsApp
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavMenu from '../../components/svelte/NavMenu.svelte';
import Footer from '../../components/astro/Footer.astro';
import SectionDivider from '../../components/astro/SectionDivider.astro';
import SectionBackground from '../../components/astro/SectionBackground.astro';
import articles from '../../data/articles.json';
import siteData from '../../data/site.json';
import { waUrl } from '../../lib/utils';
import { ArrowRight, ArrowLeft, Calendar, Clock, Share2, MessageCircle, Tag, ChevronRight } from 'lucide-svelte';

export function getStaticPaths() {
  return articles.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const idx = articles.findIndex((p) => p.slug === post.slug);
const hasPrev = idx > 0;
const hasNext = idx < articles.length - 1;
const prevPost = hasPrev ? articles[idx - 1] : null;
const nextPost = hasNext ? articles[idx + 1] : null;
const related = articles.filter((p) => p.slug !== post.slug).slice(0, 3);

const postUrl = `https://menantu-resort.com/artikel/${post.slug}/`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  image: `https://menantu-resort.com${post.image}`,
  datePublished: post.date,
  dateModified: post.date,
  author: { '@type': 'Organization', name: post.author },
  publisher: {
    '@type': 'Organization',
    name: 'Menantu Resort',
    logo: { '@type': 'ImageObject', url: 'https://menantu-resort.com/favicon.svg' }
  },
  description: post.excerpt,
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl }
};

const waMessage = waUrl(
  siteData.contact.whatsapp,
  `Saya baru baca artikel "${post.title}". Saya ingin diskusi lebih lanjut tentang investasi villa di Menantu Resort.`,
  `artikel_${post.slug}`
);

const shareJs = `navigator.share ? navigator.share({title: '${post.title.replace(/'/g, "\\'")}', url: window.location.href}).catch(() => {}) : navigator.clipboard.writeText(window.location.href).then(() => alert('Link disalin!'))`;
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>

<BaseLayout
  title={`${post.title} — Insight Menantu Resort`}
  description={post.excerpt}
  ogImage={post.image}
  canonical={postUrl}
>
  <NavMenu client:load />

  <main class="pt-20">
    <div class="bg-cream-50 border-b border-cream-100">
      <div class="container-wide py-4">
        <nav class="flex items-center gap-2 text-xs font-mono text-ink-mute" aria-label="Breadcrumb">
          <a href="/" class="hover:text-gold-700 transition-colors">Beranda</a>
          <ChevronRight size={12} />
          <a href="/artikel" class="hover:text-gold-700 transition-colors">Artikel</a>
          <ChevronRight size={12} />
          <span class="text-forest-700 truncate">{post.cat}</span>
        </nav>
      </div>
    </div>

    <article class="bg-cream-50 relative overflow-hidden">
      <div class="container-wide py-12 md:py-20 relative">
        <div class="max-w-4xl mx-auto">
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-gold-500/10 border border-gold-500/30 text-gold-700 text-xs font-bold uppercase tracking-wider">
              <Tag size={12} />
              {post.cat}
            </span>
            <span class="font-mono text-xs text-ink-mute inline-flex items-center gap-1.5">
              <Calendar size={12} />
              {post.date}
            </span>
            <span class="font-mono text-xs text-ink-mute inline-flex items-center gap-1.5">
              <Clock size={12} />
              {post.readTime} baca
            </span>
            <span class="font-mono text-xs text-gold-700 font-bold uppercase tracking-wider">
              · {post.highlight}
            </span>
          </div>

          <h1 class="font-display text-3xl md:text-5xl lg:text-6xl text-forest-700 leading-[1.05] tracking-tight font-bold mb-6">
            {post.title}
          </h1>

          <p class="font-body text-lg md:text-xl text-ink-700 leading-relaxed mb-8 max-w-3xl">
            {post.excerpt}
          </p>

          <div class="flex items-center justify-between border-t border-b border-cream-100 py-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-forest-700 text-gold-500 flex items-center justify-center font-display font-bold">
                M
              </div>
              <div>
                <div class="font-body text-sm font-semibold text-forest-700">{post.author}</div>
                <div class="font-mono text-[10px] text-ink-mute uppercase tracking-wider">Insight Menantu Resort</div>
              </div>
            </div>
            <button
              type="button"
              class="inline-flex items-center gap-2 text-sm text-ink-mute hover:text-gold-700 transition-colors"
              onclick={shareJs}
              aria-label="Bagikan artikel"
            >
              <Share2 size={16} />
              <span class="font-mono text-xs uppercase tracking-wider">Bagikan</span>
            </button>
          </div>
        </div>
      </div>
    </article>

    <div class="bg-cream-50">
      <div class="container-wide relative">
        <div class="max-w-5xl mx-auto">
          <div class="aspect-[21/9] overflow-hidden bg-forest-700">
            <img src={post.image} alt={post.title} class="w-full h-full object-cover" loading="eager" />
          </div>
        </div>
      </div>
    </div>

    <section class="bg-cream-50 relative">
      <div class="container-wide py-16 md:py-24 relative">
        <div class="max-w-3xl mx-auto">
          <div class="prose prose-lg max-w-none">
            {post.content.map((para, i) => (
              <p class:list={['font-body text-lg text-ink-700 leading-[1.8] mb-6', i === 0 ? 'text-xl md:text-2xl first-letter:text-5xl first-letter:font-display first-letter:font-bold first-letter:text-forest-700 first-letter:float-left first-letter:mr-3 first-letter:leading-none' : '']} set:html={para.replace(/\*\*(.+?)\*\*/g, '<strong class="text-forest-700 font-semibold">$1</strong>').replace(/\*(.+?)\*/g, '<em class="text-gold-700">$1</em>')} />
            ))}
          </div>

          <div class="mt-12 pt-8 border-t border-cream-100">
            <div class="font-mono text-xs text-ink-mute uppercase tracking-wider mb-3">Topik Terkait</div>
            <div class="flex flex-wrap gap-2">
              <a href="/artikel" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-cream-50 border border-cream-100 text-sm text-ink-700 hover:border-gold-500 hover:text-gold-700 transition-colors">#{post.cat}</a>
              <a href="/villa" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-cream-50 border border-cream-100 text-sm text-ink-700 hover:border-gold-500 hover:text-gold-700 transition-colors">#Villa</a>
              <a href="/investasi" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-cream-50 border border-cream-100 text-sm text-ink-700 hover:border-gold-500 hover:text-gold-700 transition-colors">#Investasi</a>
              <a href="/lokasi" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-cream-50 border border-cream-100 text-sm text-ink-700 hover:border-gold-500 hover:text-gold-700 transition-colors">#Lokasi</a>
            </div>
          </div>

          <div class="mt-12 p-8 md:p-10 bg-forest-700 text-cream-50 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/10 rounded-full blur-3xl pointer-events-none"></div>
            <div class="relative">
              <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-3 font-bold">— Diskusi Personal</div>
              <h3 class="font-display text-2xl md:text-3xl text-cream-50 mb-3 leading-tight">
                Punya pertanyaan setelah baca artikel ini?
              </h3>
              <p class="text-cream-50/80 leading-relaxed mb-6 max-w-xl">
                Tim konsultan kami siap jawab via WhatsApp — gratis, tanpa komitmen, <strong class="text-gold-500">dijawab langsung oleh tim internal MK LAND</strong> (bukan admin bot).
              </p>
              <a
                href={waMessage}
                target="_blank"
                rel="noopener"
                class="btn btn-whatsapp btn-lg"
              >
                <MessageCircle size={18} />
                Chat WhatsApp Sekarang
                <ArrowRight class="w-4 h-4" />
              </a>
            </div>
          </div>

          <nav class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-4" aria-label="Navigasi artikel">
            {prevPost ? (
              <a href={`/artikel/${prevPost.slug}/`} class="group block p-6 bg-cream-50 border border-cream-100 hover:border-gold-500 transition-colors">
                <div class="font-mono text-xs text-ink-mute uppercase tracking-wider mb-2 flex items-center gap-1">
                  <ArrowLeft size={12} /> Artikel Sebelumnya
                </div>
                <div class="font-display text-base text-forest-700 group-hover:text-gold-700 transition-colors line-clamp-2 leading-tight">
                  {prevPost.title}
                </div>
              </a>
            ) : <div></div>}
            {nextPost ? (
              <a href={`/artikel/${nextPost.slug}/`} class="group block p-6 bg-cream-50 border border-cream-100 hover:border-gold-500 transition-colors md:text-right">
                <div class="font-mono text-xs text-ink-mute uppercase tracking-wider mb-2 flex items-center md:justify-end gap-1">
                  Artikel Berikutnya <ArrowRight size={12} />
                </div>
                <div class="font-display text-base text-forest-700 group-hover:text-gold-700 transition-colors line-clamp-2 leading-tight">
                  {nextPost.title}
                </div>
              </a>
            ) : <div></div>}
          </nav>
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <section class="bg-white relative">
      <SectionBackground variant="cream" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide py-16 md:py-24 relative">
        <div class="text-center mb-12">
          <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— Lanjut Baca</div>
          <h2 class="font-display text-3xl md:text-4xl text-forest-700 leading-tight font-bold">
            Artikel <em class="text-gold-700">Lainnya</em>
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {related.map((p) => (
            <a href={`/artikel/${p.slug}/`} class="group block bg-cream-50 border border-cream-100 hover:border-gold-500 transition-all overflow-hidden">
              <div class="aspect-[16/10] overflow-hidden bg-forest-700">
                <img src={p.image} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <div class="font-mono text-[10px] uppercase tracking-widest text-gold-700 font-bold mb-2">{p.cat} · {p.readTime}</div>
                <h3 class="font-display text-base text-forest-700 font-bold group-hover:text-gold-700 transition-colors line-clamp-3 leading-tight">
                  {p.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/artikel" class="btn btn-outline btn-lg">
            Lihat Semua Artikel <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
