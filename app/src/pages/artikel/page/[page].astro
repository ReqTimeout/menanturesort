---
/**
 * /artikel/page/[page] — V5.5 pagination page 2+
 * 12 articles per page
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NavMenu from '../../../components/svelte/NavMenu.svelte';
import Footer from '../../../components/astro/Footer.astro';
import SectionDivider from '../../../components/astro/SectionDivider.astro';
import SectionBackground from '../../../components/astro/SectionBackground.astro';
import articles from '../../../data/articles.json';
import siteData from '../../../data/site.json';
import { waUrl } from '../../../lib/utils';
import { ArrowRight, Calendar, MessageCircle, TrendingUp, BookOpen, Sparkles, Award, ChevronLeft, ChevronRight, Filter } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'artikel');
const PER_PAGE = 12;
const TOTAL_PAGES = Math.ceil(articles.length / PER_PAGE);

// Sort: highest-intent "harga" first, then by date desc
const sortedArticles = [...articles].sort((a, b) => {
  if (a.slug.includes('harga-simulasi')) return -1;
  if (b.slug.includes('harga-simulasi')) return 1;
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});

// Get all unique categories
const allCategories = [...new Set(sortedArticles.map(a => a.cat))].sort();

export function getStaticPaths() {
  const PER_PAGE_LOCAL = 12;
  const totalPagesLocal = Math.ceil(articles.length / PER_PAGE_LOCAL);
  const pagesLocal = [];
  for (let pp = 2; pp <= totalPagesLocal; pp++) {
    pagesLocal.push({ params: { page: String(pp) } });
  }
  return pagesLocal;
}

const { page } = Astro.params;
const CURRENT_PAGE = parseInt(page, 10);

if (CURRENT_PAGE < 2 || CURRENT_PAGE > TOTAL_PAGES) {
  return Astro.redirect('/artikel/');
}

const featured = sortedArticles[0]; // For breadcrumb reference
// For page N: skip featured (1) + (N-1) * 12 articles, take next 12
const startIdx = 1 + (CURRENT_PAGE - 2) * PER_PAGE;
const endIdx = startIdx + PER_PAGE;
const grid = sortedArticles.slice(startIdx, endIdx);

const prevPage = CURRENT_PAGE > 1 ? CURRENT_PAGE - 1 : null;
const nextPage = CURRENT_PAGE < TOTAL_PAGES ? CURRENT_PAGE + 1 : null;
const pageHref = (p) => p === 1 ? '/artikel/' : `/artikel/page/${p}/`;
const pageNumbers = Array.from({ length: TOTAL_PAGES }, (_, i) => i + 1);

// Pre-compute pagination items (smart window: 1, 2 ... current-1, current, current+1 ... last-1, last)
const paginationItems = (() => {
  const items = [];
  for (const p of pageNumbers) {
    const isFirst = p === 1;
    const isLast = p === TOTAL_PAGES;
    const isCurrent = p === CURRENT_PAGE;
    const isNear = Math.abs(p - CURRENT_PAGE) <= 1;
    const isEllipsisBefore = p === CURRENT_PAGE - 2 && CURRENT_PAGE > 4;
    const isEllipsisAfter = p === CURRENT_PAGE + 2 && CURRENT_PAGE < TOTAL_PAGES - 3;
    if (isFirst || isLast || isCurrent || isNear) {
      items.push({ type: isCurrent ? 'current' : 'page', page: p, href: pageHref(p) });
    } else if (isEllipsisBefore || isEllipsisAfter) {
      items.push({ type: 'ellipsis' });
    }
  }
  return items;
})();

const startItem = startIdx + 1;
const endItem = Math.min(startIdx + grid.length, articles.length);
---

<BaseLayout
  title={`Artikel Halaman ${CURRENT_PAGE} — Insight Villa Bandung | Menantu Resort`}
  description={`Halaman ${CURRENT_PAGE} dari ${TOTAL_PAGES} — Insight properti, simulasi KPR, dan review jujur investasi villa di Bandung Timur. ${articles.length} artikel total.`}
  canonical={`https://menantu-resort.com/artikel/page/${CURRENT_PAGE}/`}
>
  <NavMenu client:load />

  <main>
    <!-- HERO (compact for page 2+) -->
    <section class="relative bg-forest-700 text-cream-50 overflow-hidden pt-28 pb-12 md:pt-36 md:pb-16">
      <SectionBackground variant="forest" pattern={true} orbs={true} intensity="medium" />
      <div class="container-wide relative">
        <div class="max-w-4xl">
          <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-4 font-bold flex items-center gap-2">
            <BookOpen size={14} /> Insight · Halaman {CURRENT_PAGE} dari {TOTAL_PAGES}
          </div>
          <h1 class="font-display text-3xl md:text-5xl text-cream-50 leading-[1.05] tracking-tight mb-5">
            Artikel <em class="text-gold-500">halaman {CURRENT_PAGE}</em>
          </h1>
          <p class="font-body text-base md:text-lg text-cream-50/85 leading-relaxed max-w-2xl">
            Lanjut eksplorasi insight properti Bandung, simulasi KPR, dan review kompetitor. Total {articles.length} artikel siap dibaca — bebas, tanpa registrasi.
          </p>

          <!-- Trust strip -->
          <div class="mt-8 pt-6 border-t border-gold-500/20 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs font-mono text-cream-50/70">
            <span class="inline-flex items-center gap-1.5"><Sparkles size={12} class="text-gold-500" /> {articles.length} artikel</span>
            <span class="inline-flex items-center gap-1.5"><Award size={12} class="text-gold-500" /> Tim MK LAND + Sahid</span>
            <span class="inline-flex items-center gap-1.5"><TrendingUp size={12} class="text-gold-500" /> Update mingguan</span>
            <span class="inline-flex items-center gap-1.5"><Filter size={12} class="text-gold-500" /> {allCategories.length} kategori</span>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- GRID + PAGINATION -->
    <section class="bg-cream-50 relative">
      <div class="container-wide py-12 md:py-20 relative">
        <div class="flex flex-wrap items-end justify-between gap-3 mb-8">
          <div>
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-2 font-semibold">— Halaman {CURRENT_PAGE}</div>
            <h2 class="font-display text-2xl md:text-3xl text-forest-700 font-bold leading-tight">
              Menampilkan artikel <em class="text-gold-700">{startItem}–{endItem}</em>
            </h2>
          </div>
          <div class="font-mono text-xs text-ink-mute uppercase tracking-wider">
            {articles.length} artikel total · {TOTAL_PAGES} halaman
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-7">
          {grid.map((p) => (
            <a
              href={`/artikel/${p.slug}/`}
              class="card-premium group overflow-hidden flex flex-col h-full hover:shadow-2xl transition-shadow"
            >
              <div class="relative aspect-[16/10] overflow-hidden bg-forest-700">
                <img src={p.image} alt={p.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" width="640" height="400" />
                <div class="absolute inset-0 bg-gradient-to-t from-forest-900/40 via-transparent to-transparent"></div>
                <div class="absolute top-3 left-3">
                  <span class="badge badge-gold text-[10px] uppercase tracking-wider font-bold">{p.cat}</span>
                </div>
                <div class="absolute top-3 right-3">
                  <span class="px-2 py-1 bg-forest-900/80 backdrop-blur text-cream-50 text-[10px] font-mono uppercase tracking-wider">{p.readTime}</span>
                </div>
              </div>
              <div class="p-5 md:p-6 flex-1 flex flex-col">
                <div class="flex items-center gap-2 mb-2.5 text-[11px] text-ink-mute font-mono">
                  <Calendar size={10} />
                  <span>{p.date}</span>
                </div>
                <h3 class="font-display text-base md:text-lg text-forest-700 font-bold mb-2.5 group-hover:text-gold-700 transition-colors leading-snug line-clamp-3">
                  {p.title}
                </h3>
                <p class="text-sm text-ink-soft leading-relaxed mb-4 flex-1 line-clamp-3">{p.excerpt}</p>
                <div class="flex items-center justify-between mt-auto pt-3 border-t border-cream-100">
                  <span class="text-[11px] text-gold-700 font-bold uppercase tracking-wider">{p.highlight}</span>
                  <span class="text-gold-700 text-xs font-bold inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all">
                    Baca <ArrowRight size={12} />
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- PAGINATION -->
        <nav class="mt-14 md:mt-20" aria-label="Pagination">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-5">
            <div class="font-mono text-[11px] text-ink-mute uppercase tracking-wider order-2 sm:order-1">
              Menampilkan {startItem}–{endItem} dari {articles.length}
            </div>
            <div class="flex items-center gap-1.5 order-1 sm:order-2 flex-wrap justify-center">
              {prevPage && (
                <a href={pageHref(prevPage)} class="inline-flex items-center gap-1 px-3 py-2 bg-white border border-cream-100 hover:border-gold-500 text-ink-700 text-sm font-mono uppercase tracking-wider transition-colors">
                  <ChevronLeft size={14} /> Prev
                </a>
              )}
              {paginationItems.map((item) => {
                if (item.type === 'ellipsis') {
                  return <span class="px-2 text-ink-mute">…</span>;
                }
                const isCurrent = item.type === 'current';
                return (
                  <a
                    href={item.href}
                    class={`min-w-[40px] h-10 inline-flex items-center justify-center text-sm font-mono font-bold transition-colors ${
                      isCurrent
                        ? 'bg-forest-700 text-gold-500 border border-forest-700'
                        : 'bg-white border border-cream-100 text-ink-700 hover:border-gold-500 hover:text-gold-700'
                    }`}
                    aria-current={isCurrent ? 'page' : undefined}
                  >
                    {item.page}
                  </a>
                );
              })}
              {nextPage && (
                <a href={pageHref(nextPage)} class="inline-flex items-center gap-1 px-3 py-2 bg-white border border-cream-100 hover:border-gold-500 text-ink-700 text-sm font-mono uppercase tracking-wider transition-colors">
                  Next <ChevronRight size={14} />
                </a>
              )}
            </div>
          </div>
        </nav>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- CTA -->
    <section class="relative section-cream py-16 md:py-24 gsap-fade" data-section="cta">
      <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative text-center">
        <div class="max-w-2xl mx-auto">
          <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-4 font-semibold">— Konsultasi Personal</div>
          <h2 class="font-display text-3xl md:text-4xl text-forest-700 leading-tight mb-5">
            Punya pertanyaan setelah baca <em class="text-gold-700">artikel</em>?
          </h2>
          <p class="text-ink-700 text-base md:text-lg leading-relaxed mb-7">
            Tim konsultan internal Sahid siap jawab via WhatsApp — gratis, tanpa komitmen, dibalas dalam 5 menit (Senin–Sabtu 09.00–18.00 WIB).
          </p>
          <a
            href={waLink('Halo, saya mau konsultasi gratis via WhatsApp setelah baca artikel.')}
            target="_blank"
            rel="noopener"
            onclick="typeof gtag_report_conversion==='function' && gtag_report_conversion('https://wa.me/6285925942277');"
            class="btn btn-whatsapp btn-lg"
          >
            <MessageCircle size={18} /> Chat WhatsApp Sekarang <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
