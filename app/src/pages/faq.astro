---
/**
 * /faq — V5.2 rewrite (PageHero + Accordion + Final CTA)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import PageHero from '../components/astro/PageHero.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import Pattern from '../components/astro/Pattern.astro';
import Accordion from '../lib/components/ui/Accordion.svelte';
import faqData from '../data/faq.json';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { MessageCircle, ArrowRight } from 'lucide-svelte';

const waLink = waUrl(siteData.contact.whatsapp, 'Halo, saya masih ada pertanyaan tentang investasi', 'faq');
---

<BaseLayout title="FAQ — Pertanyaan Umum Investasi Vila" description="22 Q&A tentang investasi vila Menantu Resort: skema pembelian, passive income, legal, lokasi, manajemen, pembayaran.">
  <NavMenu client:load />

  <main class="pt-20">
    <PageHero
      eyebrow="Pertanyaan Umum"
      title="FAQ —"
      accent="Jawaban Jujur untuk Investor."
      description="22 pertanyaan yang paling sering ditanyakan calon investor, dijawab langsung dengan data — bukan jargon marketing."
      primaryCta={{ text: 'Chat WhatsApp', href: waLink }}
      stats={[
        { value: '22', label: 'Q&A' },
        { value: '6', label: 'Kategori' },
        { value: 'Data', label: 'Based' },
      ]}
      bgColor="cream"
    />

    <SectionDivider variant="diamond" />

    <!-- FAQ Accordion -->
    <section class="relative bg-white py-20 md:py-32" data-section="faq-list">
      <Pattern variant="dots-dense" color="forest" opacity={0.04} />
      <div class="container-wide relative space-y-12">
        {faqData.map((category) => (
          <div>
            <h2 class="font-display text-3xl text-forest-700 mb-6 pb-3 border-b-2 border-gold-500">{category.category}</h2>
            <Accordion client:load items={category.items} />
          </div>
        ))}

        <SectionDivider variant="ornate" />

        <div class="text-center mt-16 card-premium p-10 bg-forest-50">
          <h3 class="font-display text-2xl text-forest-700 mb-3">Masih ada pertanyaan lain?</h3>
          <p class="text-base text-ink-soft mb-6">Tim kami siap jawab personal via WhatsApp — gratis, tanpa komitmen.</p>
          <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle class="w-4 h-4" /> Tanya via WhatsApp
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
