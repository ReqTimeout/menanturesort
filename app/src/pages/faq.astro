---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import WhatsAppFloating from '../components/astro/WhatsAppFloating.astro';
import Accordion from '../lib/components/ui/Accordion.svelte';
import faqData from '../data/faq.json';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { MessageCircle } from 'lucide-svelte';

const waLink = waUrl(siteData.contact.whatsapp, 'Halo, saya masih ada pertanyaan tentang investasi', 'faq');
---
<BaseLayout title="FAQ — Pertanyaan Umum Investasi Vila" description="22 Q&A tentang investasi vila Menantu Resort: skema pembelian, passive income, legal, lokasi, manajemen, pembayaran.">
  <Navbar />
  <main class="pt-20">
    <section class="section section-cream">
      <div class="container-tight text-center">
        <span class="eyebrow">Pertanyaan Umum</span>
        <h1 class="heading-title mt-4 mb-6">FAQ — <em>Jawaban Jujur</em> untuk Investor.</h1>
        <p class="text-body-lg text-ink-500 max-w-2xl mx-auto">22 pertanyaan yang paling sering ditanyakan calon investor, dijawab langsung dengan data — bukan jargon marketing.</p>
      </div>
    </section>

    <section class="section-tight section-white">
      <div class="container-tight">
        <div class="space-y-12">
          {faqData.map((category) => (
            <div>
              <h2 class="heading text-2xl mb-4 pb-3 border-b-2 border-gold-500">{category.category}</h2>
              <Accordion client:visible items={category.items} />
            </div>
          ))}
        </div>

        <div class="text-center mt-16 card p-10 bg-forest-50">
          <p class="text-body-lg text-ink-500 mb-6">Masih ada pertanyaan lain?</p>
          <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle size="18" /> Tanya via WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloating />
</BaseLayout>
