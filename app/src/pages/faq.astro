---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import WhatsAppFloating from '../components/astro/WhatsAppFloating.astro';
import siteData from '../data/site.json';
import faqData from '../data/faq.json';
import { waUrl } from '../lib/format';

const waLink = waUrl(siteData.contact.whatsapp, 'Halo, saya ada pertanyaan tentang Menantu Resort', 'faq_page');
---
<BaseLayout
  title="FAQ — Pertanyaan Umum Seputar Investasi Villa"
  description="Jawaban lengkap untuk pertanyaan tentang KPR, passive income, SHM, dan skema investasi Menantu Resort. Mulai dari booking fee hingga capital gain 15 tahun."
>
  <Navbar />

  <main class="pt-32 pb-3xl">
    <div class="container-narrow">
      <div class="text-center mb-2xl">
        <span class="eyebrow">Frequently Asked Questions</span>
        <h1 class="heading-1">Pertanyaan yang Sering Ditanyakan</h1>
        <p class="text-body-lg mt-md">
          Tidak menemukan jawabannya? <a href={waLink} target="_blank" rel="noopener" class="text-secondary font-semibold hover:underline">Chat langsung dengan tim sales →</a>
        </p>
      </div>

      {faqData.map((group, gi) => (
        <section class="mb-2xl">
          <h2 class="heading-3 mb-md flex items-center gap-sm">
            <span class="text-secondary">0{gi + 1}.</span>
            {group.category}
          </h2>
          <div class="space-y-sm">
            {group.items.map((item, i) => (
              <details class="card p-lg group" open={gi === 0 && i === 0}>
                <summary class="cursor-pointer flex items-center justify-between font-semibold text-text hover:text-primary">
                  <span>{item.q}</span>
                  <svg class="w-5 h-5 text-secondary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <p class="mt-md text-body text-gray-700 leading-relaxed">
                  {item.a}
                </p>
              </details>
            ))}
          </div>
        </section>
      ))}

      <!-- CTA Bottom -->
      <div class="card bg-gradient-card text-white p-xl mt-3xl text-center">
        <h3 class="heading-3 text-white mb-md">Masih Ada Pertanyaan?</h3>
        <p class="text-white/80 mb-lg">
          Tim sales kami siap membantu via WhatsApp. Konsultasi gratis, tidak ada pressure.
        </p>
        <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
          💬 Chat WhatsApp Sekarang
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <WhatsAppFloating />
</BaseLayout>

<!-- FAQ Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqData.flatMap(g => g.items).map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
})} />
