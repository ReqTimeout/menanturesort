---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import WhatsAppFloating from '../components/astro/WhatsAppFloating.astro';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { MessageCircle, Waves, Building2, Coffee, Dumbbell, Trophy, Church, Gamepad2, Footprints, Car, Shield, Mountain, ArrowRight } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'resort');

const fasilitas = [
  { icon: Waves, name: 'Infinity Pool', desc: '15×6m dengan view perbukitan' },
  { icon: Building2, name: 'Ballroom', desc: '500 pax untuk event & gathering' },
  { icon: Coffee, name: 'Restaurant', desc: 'Open-air, 80 seat, menu lokal & internasional' },
  { icon: Coffee, name: 'Café & Lounge', desc: 'Coffee shop dengan WiFi kencang' },
  { icon: Dumbbell, name: 'Fitness Center', desc: '24 jam, peralatan lengkap' },
  { icon: Trophy, name: 'Golf & Tennis', desc: 'Mini golf + tennis court profesional' },
  { icon: Church, name: 'Mosque', desc: 'Masjid resort kapasitas 200' },
  { icon: Gamepad2, name: 'Playground', desc: 'Area bermain anak, family-friendly' },
  { icon: Footprints, name: 'Jogging Track', desc: '2 km track view taman tropis' },
  { icon: Car, name: 'Charging Station', desc: 'EV charger + parking 200 mobil' },
  { icon: Shield, name: '24/7 Security', desc: 'Private access, CCTV, security patrol' },
  { icon: Mountain, name: '360° View Deck', desc: 'Sunset deck, photo spot, yoga space' },
];
---
<BaseLayout title="Fasilitas Resort — Standar Hotel Bintang 5" description="12 fasilitas premium: infinity pool, ballroom, restaurant, fitness, golf, 24/7 security. Standar Sahid Hotel.">
  <Navbar />
  <main class="pt-20">
    <section class="section section-cream">
      <div class="container-tight text-center">
        <span class="eyebrow">Fasilitas Resort</span>
        <h1 class="heading-title mt-4 mb-6">Standar Hotel Bintang 5, <br/><em>untuk Vila Pribadi Anda.</em></h1>
        <p class="text-body-lg text-ink-500 max-w-2xl mx-auto">12 fasilitas premium yang dioperasikan tim Sahid setiap hari — dari housekeeping bintang 5 hingga maintenance preventif.</p>
      </div>
    </section>

    <section class="section-tight section-white">
      <div class="container-tight">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {fasilitas.map((f) => {
            const Icon = f.icon;
            return (
              <div class="card p-8 hover:border-gold-500 transition group">
                <Icon size="36" class="text-gold-700 mb-4" strokeWidth="1.5" />
                <h3 class="font-display text-xl text-forest-700 font-semibold mb-2">{f.name}</h3>
                <p class="text-sm text-ink-500">{f.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container-tight text-center max-w-3xl">
        <span class="eyebrow">Dikelola Oleh</span>
        <h2 class="heading-title mt-4 mb-6">Sahid Hotel & Resort <em>50+ Tahun.</em></h2>
        <p class="text-body-lg text-ink-500 mb-8">Tim operasional Sahid yang sudah mengelola 20+ hotel & resort di Indonesia akan menangani vila Anda setiap hari — dari kebersihan hingga marketing.</p>
        <a href={waLink('Halo, saya mau tau manajemen Sahid')} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
          Pelajari Manajemen Sahid <ArrowRight size="18" />
        </a>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppFloating />
</BaseLayout>
