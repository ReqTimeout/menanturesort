---
/**
 * /resort — V5.3 rewrite (storytelling + 12 fasilitas + Sahid credentials)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import PageHero from '../components/astro/PageHero.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import SectionBackground from '../components/astro/SectionBackground.astro';
import { waUrl } from '../lib/utils';
import { MessageCircle, Waves, Building2, Coffee, Dumbbell, Trophy, Church, Gamepad2, Footprints, Car, Shield, Mountain, ArrowRight, Sparkles, Users } from 'lucide-svelte';
import siteData from '../data/site.json';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'resort');

const fasilitas = [
  { icon: Waves, name: 'Infinity Pool', desc: '15×6m, view perbukitan hijau — sunset reflection yang viral di Instagram.', tag: 'Signature' },
  { icon: Building2, name: 'Ballroom', desc: '500 pax untuk event corporate, wedding, gathering.', tag: '500 pax' },
  { icon: Coffee, name: 'Restaurant', desc: 'Open-air, 80 seat, menu lokal & internasional, breakfast included.', tag: '80 seat' },
  { icon: Coffee, name: 'Café & Lounge', desc: 'Coffee shop specialty, WiFi 1 Gbps, kerja remote friendly.', tag: 'WiFi 1Gbps' },
  { icon: Dumbbell, name: 'Fitness Center', desc: '24 jam, peralatan Technogym, personal trainer on-call.', tag: '24/7' },
  { icon: Trophy, name: 'Golf & Tennis', desc: 'Mini golf + tennis court profesional, bisa private lesson.', tag: 'Pro Court' },
  { icon: Church, name: 'Mosque', desc: 'Masjid resort kapasitas 200, AC, sound system premium.', tag: '200 capacity' },
  { icon: Gamepad2, name: 'Playground', desc: 'Area bermain anak, family-friendly, supervised saat weekend.', tag: 'Family' },
  { icon: Footprints, name: 'Jogging Track', desc: '2 km track view taman tropis, 6 zona exercise outdoor.', tag: '2 km' },
  { icon: Car, name: 'Charging Station', desc: 'EV charger universal + parking 200 mobil, valet service.', tag: 'EV Ready' },
  { icon: Shield, name: '24/7 Security', desc: 'Private access gate, CCTV 64 titik, security patrol 3 shift.', tag: '3 Shift' },
  { icon: Mountain, name: '360° View Deck', desc: 'Sunset deck, photo spot, yoga space, BBQ pit setiap weekend.', tag: 'Sunset' },
];
---

<BaseLayout
  title="Fasilitas Resort Bintang 5 untuk Vila Anda — Dikelola Sahid | Menantu Resort"
  description="12 fasilitas premium yang dioperasionalkan tim Sahid setiap hari — dari housekeeping bintang 5, infinity pool 15×6m view perbukitan, ballroom 500 pax, hingga EV charging station. Standar hotel bintang 5, biaya operasional 70/30 profit sharing."
>
  <NavMenu client:load />

  <main class="pt-20">
    <PageHero
      eyebrow="Fasilitas Resort"
      title="Standar Hotel Bintang 5,"
      accent="untuk Vila Pribadi Anda."
      description="Bayangkan Anda memiliki villa pribadi, tapi setiap hari dibersihkan, dirawat, dan di-maintain oleh tim housekeeping hotel bintang 5. Tamu datang, check-in, tinggal nikmati. Anda? Tinggal terima passive income. Itulah Menantu Resort."
      primaryCta={{ text: 'Lihat Villa', href: '/villa' }}
      secondaryCta={{ text: 'Konsultasi', href: waLink('Halo, saya ingin tau detail fasilitas resort.') }}
      stats={[
        { value: '12', label: 'Fasilitas Premium' },
        { value: '24/7', label: 'Operasional' },
        { value: '50+', label: 'Tahun Sahid' },
      ]}
      bgColor="cream"
    />

    <SectionDivider variant="diamond" />

    <!-- 12 Fasilitas Grid -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade">
    data-section="fasilitas">
      <SectionBackground variant="cream" pattern={true} orbs={true} intensity="subtle" />
      <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-16">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— 12 Fasilitas</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-4">
              Semua yang Anda <em class="text-gold-700">butuhkan</em>, di satu tempat
            </h2>
            <p class="font-body text-lg text-ink-soft max-w-3xl leading-relaxed">
              Standar resort bintang 5 — dioperasionalkan tim profesional Sahid setiap hari. Anda tidak perlu pusing soal maintenance, housekeeping, atau marketing. <em class="text-gold-700">Tinggal terima passive income</em>.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {fasilitas.map((f, i) => {
            const Icon = f.icon;
            return (
              <div class="card-premium p-7 hover:scale-[1.02] transition-all duration-300 group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gold-500/5 rounded-full blur-2xl group-hover:bg-gold-500/15 transition-colors"></div>
                <div class="relative">
                  <div class="flex items-start justify-between mb-4">
                    <div class="w-14 h-14 bg-forest-700 text-gold-500 flex items-center justify-center group-hover:bg-gold-500 group-hover:text-forest-700 transition-colors">
                      <Icon size={26} strokeWidth="1.5" />
                    </div>
                    <span class="font-mono text-xs text-gold-700 uppercase tracking-wider font-bold">{f.tag}</span>
                  </div>
                  <div class="font-mono text-xs text-gold-500 mb-2 font-bold">0{i + 1}</div>
                  <h3 class="font-display text-xl text-forest-700 font-bold mb-2 leading-tight">{f.name}</h3>
                  <p class="text-sm text-ink-soft leading-relaxed">{f.desc}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- Operasional — daily life -->
    <section class="relative section-cream py-20 md:py-32 gsap-fade">
    data-section="operasional">
      <SectionBackground variant="gold" pattern={true} orbs={true} intensity="subtle" />
      <SectionBackground variant="forest" pattern={true} orbs={true} intensity="subtle" />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-16">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3 font-semibold">— Operasional Harian</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-4">
              Vila Anda, <em class="text-gold-700">dikelola seperti hotel bintang 5</em>
            </h2>
            <p class="font-body text-lg text-ink-soft max-w-3xl leading-relaxed">
              Setiap hari, tim Sahid menjalankan SOP hospitality yang sama dengan 20+ hotel mereka. Anda tidak perlu pusing — passive income mengalir otomatis ke rekening.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="card-premium p-7 text-center">
            <div class="font-display text-4xl text-gold-700 mb-2 font-bold">06.00</div>
            <div class="font-mono text-xs uppercase tracking-widest text-forest-700 mb-3 font-semibold">Housekeeping Pagi</div>
            <p class="text-sm text-ink-soft leading-relaxed">Turn-down service, fresh linen, ambient fragrance.</p>
          </div>
          <div class="card-premium p-7 text-center">
            <div class="font-display text-4xl text-gold-700 mb-2 font-bold">10.00</div>
            <div class="font-mono text-xs uppercase tracking-widest text-forest-700 mb-3 font-semibold">Maintenance Check</div>
            <p class="text-sm text-ink-soft leading-relaxed">Pool chemistry, AC filter, pest control, garden care.</p>
          </div>
          <div class="card-premium p-7 text-center">
            <div class="font-display text-4xl text-gold-700 mb-2 font-bold">14.00</div>
            <div class="font-mono text-xs uppercase tracking-widest text-forest-700 mb-3 font-semibold">Guest Check-in</div>
            <p class="text-sm text-ink-soft leading-relaxed">Welcome drink, room tour, 24/7 concierge WhatsApp.</p>
          </div>
          <div class="card-premium p-7 text-center">
            <div class="font-display text-4xl text-gold-700 mb-2 font-bold">20.00</div>
            <div class="font-mono text-xs uppercase tracking-widest text-forest-700 mb-3 font-semibold">Evening Turn-down</div>
            <p class="text-sm text-ink-soft leading-relaxed">Night service, chocolate, turn-down ritual signature Sahid.</p>
          </div>
        </div>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- Sahid Management -->
    <section class="relative bg-forest-900 text-cream-50 py-20 md:py-32 overflow-hidden gsap-fade" data-section="sahid">
      <SectionBackground variant="dark" pattern={true} orbs={true} intensity="strong" />
      <div class="container-wide relative">
        <div class="text-center max-w-4xl mx-auto mb-16">
          <div class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-4 font-semibold">— Dikelola Oleh</div>
          <h2 class="font-display text-display-md text-cream-50 leading-[0.95] tracking-tight mb-6">
            Sahid Hotel & Resort, <em class="text-gold-500">50+ tahun track record</em>
          </h2>
          <p class="font-body text-lg text-cream-50/80 max-w-3xl mx-auto leading-relaxed">
            Anda menitipkan villa Anda pada operator yang sudah mengelola 20+ hotel & resort ternama di Indonesia. Mulai dari Grand Sahid Jaya Jakarta, Sahid Resort Yogyakarta, hingga Sahid Skyland City Jatinangor. Standar operasional, marketing, dan revenue management Anda sudah proven.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
          <div class="text-center">
            <div class="font-display text-5xl text-gold-500 font-bold mb-2">20+</div>
            <div class="text-cream-50/70 text-sm uppercase tracking-wider">Properti Aktif</div>
          </div>
          <div class="text-center">
            <div class="font-display text-5xl text-gold-500 font-bold mb-2">50+</div>
            <div class="text-cream-50/70 text-sm uppercase tracking-wider">Tahun Pengalaman</div>
          </div>
          <div class="text-center">
            <div class="font-display text-5xl text-gold-500 font-bold mb-2">8</div>
            <div class="text-cream-50/70 text-sm uppercase tracking-wider">Hotel Signature</div>
          </div>
          <div class="text-center">
            <div class="font-display text-5xl text-gold-500 font-bold mb-2">70%</div>
            <div class="text-cream-50/70 text-sm uppercase tracking-wider">Owner Share</div>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 justify-center">
          <a href={waLink('Halo, saya mau diskusi detail manajemen Sahid untuk villa saya.')} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <MessageCircle size={18} /> Diskusi dengan Tim Sahid
          </a>
          <a href="/villa" class="btn btn-outline btn-lg">Lihat 3 Tipe Villa <ArrowRight class="w-4 h-4" /></a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
