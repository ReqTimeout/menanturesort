---
/**
 * /resort — V5.2 rewrite (PageHero + 12 Fasilitas + Sahid)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NavMenu from '../components/svelte/NavMenu.svelte';
import Footer from '../components/astro/Footer.astro';
import PageHero from '../components/astro/PageHero.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import Pattern from '../components/astro/Pattern.astro';
import siteData from '../data/site.json';
import { waUrl } from '../lib/utils';
import { MessageCircle, Waves, Building2, Coffee, Dumbbell, Trophy, Church, Gamepad2, Footprints, Car, Shield, Mountain, ArrowRight } from 'lucide-svelte';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'resort');

const fasilitas = [
  { icon: Waves, name: 'Infinity Pool', desc: '15×6m dengan view perbukitan' },
  { icon: Building2, name: 'Ballroom', desc: '500 pax untuk event & gathering' },
  { icon: Coffee, name: 'Restaurant', desc: 'Open-air, 80 seat, menu lokal & internasional' },
  { icon: Coffee, name: 'Café & Lounge', desc: 'Coffee shop dengan WiFi kencang' },
  { icon: Dumbbell, name: 'Fitness Center', desc: '24 jam, peralatan lengkap' },
  { icon: Trophy, name: 'Golf & Tennis', desc: 'Mini golf + tennis court profesional' },
  { icon: Church, name: 'Mosque', desc: 'Masjid resort kapasitas 200' },
  { icon: Gamepad2, name: 'Playground', desc: 'Area bermain anak, family-friendly' },
  { icon: Footprints, name: 'Jogging Track', desc: '2 km track view taman tropis' },
  { icon: Car, name: 'Charging Station', desc: 'EV charger + parking 200 mobil' },
  { icon: Shield, name: '24/7 Security', desc: 'Private access, CCTV, security patrol' },
  { icon: Mountain, name: '360° View Deck', desc: 'Sunset deck, photo spot, yoga space' },
];
---

<BaseLayout
  title="Fasilitas Resort Standar Bintang 5 — Menantu Resort"
  description="12 fasilitas premium yang dioperasionalkan tim Sahid setiap hari. Dari housekeeping bintang 5 hingga maintenance preventif."
>
  <NavMenu client:load />

  <main class="pt-20">
    <PageHero
      eyebrow="Fasilitas Resort"
      title="Standar Hotel Bintang 5,"
      accent="untuk Vila Pribadi Anda."
      description="12 fasilitas premium yang dioperasionalkan tim Sahid setiap hari — dari housekeeping bintang 5 hingga maintenance preventif."
      primaryCta={{ text: 'Lihat Villa', href: '/villa' }}
      secondaryCta={{ text: 'Konsultasi', href: waLink('Halo, saya ingin tau detail fasilitas resort') }}
      stats={[
        { value: '12', label: 'Fasilitas' },
        { value: '24/7', label: 'Operasional' },
        { value: '50+', label: 'Tahun Sahid' },
      ]}
      bgColor="cream"
    />

    <SectionDivider variant="diamond" />

    <!-- 12 Fasilitas Grid -->
    <section class="relative bg-white py-20 md:py-32 gsap-fade" data-section="fasilitas">
      <Pattern variant="dots" color="gold" opacity={0.05} />
      <div class="container-wide relative">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— 12 Fasilitas</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight">
              Semua yang Anda <em class="text-gold-700">butuhkan</em>
            </h2>
            <p class="font-body text-lg text-ink-soft mt-4 max-w-2xl">
              Standar resort bintang 5, dioperasionalkan tim profesional setiap hari.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {fasilitas.map((f) => {
            const Icon = f.icon;
            return (
              <div class="card-premium p-8 hover:scale-[1.02] transition-transform group">
                <div class="w-14 h-14 bg-forest-700 text-gold-500 flex items-center justify-center mb-4 group-hover:bg-gold-500 group-hover:text-forest-700 transition-colors">
                  <Icon size={24} strokeWidth="1.5" />
                </div>
                <h3 class="font-display text-xl text-forest-700 font-semibold mb-2">{f.name}</h3>
                <p class="text-sm text-ink-soft">{f.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- Sahid Management -->
    <section class="relative section-cream py-20 md:py-32 gsap-fade" data-section="sahid">
      <Pattern variant="gold-sparkle" color="gold" opacity={0.05} />
      <div class="container-wide relative text-center max-w-3xl mx-auto">
        <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— Dikelola Oleh</div>
        <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight mb-6">
          Sahid Hotel & Resort <em class="text-gold-700">50+ tahun</em>
        </h2>
        <p class="font-body text-lg text-ink-soft mb-8">
          Tim operasional Sahid yang sudah mengelola 20+ hotel & resort di Indonesia akan menangani vila Anda setiap hari — dari kebersihan hingga marketing.
        </p>
        <a href={waLink('Halo, saya mau tau manajemen Sahid')} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
          Pelajari Manajemen Sahid <ArrowRight class="w-4 h-4" />
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
