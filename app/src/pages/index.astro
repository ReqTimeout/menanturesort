---
/**
 * Homepage V5.2 — 11 sections, 7-ribuan px scroll
 * Setiap section punya narrative role (hook / value / proof / cta).
 * Pattern: Concerns → Solution (proven dari existing), bukan template per-section.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/astro/Footer.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import siteData from '../data/site.json';
import villaData from '../data/villa.json';

import NavMenu from '../components/svelte/NavMenu.svelte';
import EditorialHero from '../components/svelte/EditorialHero.svelte';
import InlineLeadForm from '../components/svelte/InlineLeadForm.svelte';
import Marquee from '../components/svelte/Marquee.svelte';
import ThePromise from '../components/svelte/ThePromise.svelte';
import HowItWorks from '../components/svelte/HowItWorks.svelte';
import TestimoniCarousel from '../components/svelte/TestimoniCarousel.svelte';

// V5.2 NEW sections
import ConcernsSection from '../components/svelte/ConcernsSection.svelte';
import SolutionSection from '../components/svelte/SolutionSection.svelte';
import PilihanResortSection from '../components/svelte/PilihanResortSection.svelte';
import PopularitasTipeSection from '../components/svelte/PopularitasTipeSection.svelte';
import VirtualTourSection from '../components/svelte/VirtualTourSection.svelte';
import PromoSpesialSection from '../components/svelte/PromoSpesialSection.svelte';
import FinalCTASection from '../components/svelte/FinalCTASection.svelte';
import MidCTA from '../components/svelte/MidCTA.svelte';

// ── Hero data ──
const heroTitle = 'Masa Depan';
const heroAccent = 'Lebih Mapan.';
const heroEyebrow = '01 / Investment Edition · 2026';
const heroBadge = '⚡ Limited Release · 16 dari 74 unit tersisa';
const heroBody = 'Bayangkan: setiap bulan, villa resort Anda di Bandung Timur menghasilkan passive income Rp 9-15 juta — cukup menutup cicilan KPR. Dikelola harian oleh Sahid Hotels & Resorts, 50+ tahun track record. SHM Bersih. ROI 10% guarantee.';

// ── Marquee — Trust + FOMO + Storytelling ──
const marqueeItems = [
  '<span class="highlight">SHM Bersih</span> · Bukan Hak Pakai · Aset Warisan Sejati',
  '<span class="highlight">Dikelola Sahid</span> · 50+ Tahun Track Record Hospitality',
  '<span class="highlight">ROI 10%</span> / Tahun · Guarantee 2 Tahun Pertama',
  'Passive Income <span class="highlight">Rp 9–15 Juta</span> / Bulan · Otomatis',
  'Cicilan Mulai <span class="highlight">Rp 9 Juta</span> / Bulan · KPR 20 Tahun',
  'Sisa <span class="highlight">16 dari 74 Unit</span> · Sebelum Sold Out',
  'Free <span class="highlight">BPJS + PBB + IPL</span> · Tahun Pertama',
  'Survey Lokasi <span class="highlight">GRATIS</span> · Shuttle dari Bandung · Setiap Sabtu',
  'Booking Fee Hanya <span class="highlight">Rp 5 Juta</span> · Refundable 30 Hari',
  '<span class="highlight">Free Stay 2 Malam</span> · 50 Buyer Pertama',
  'Promo <span class="highlight">Cashback Rp 50 Juta</span> · Berlaku Juni 2026',
  'Buyer Hari Ini · Bonus <span class="highlight">Souvenir Eksklusif Sahid</span>',
  'Capital Gain <span class="highlight">2,2–3,3 Miliar</span> · 10 Tahun Proyeksi',
  '<span class="highlight">Cicilan Lebih Kecil</span> dari Income · Cashflow Positif Hari 1',
  '<span class="highlight">Sahid Standard</span> · Material, Finishing, Service Bintang 5',
  '<span class="highlight">Bandung Timur</span> · Cicalengka · 35 Menit dari Tol Cisumdawu',
  'Lokasi <span class="highlight">3,5 Hektar</span> Eco-Resort Private & Tenang',
  'Akses <span class="highlight">12 Fasilitas Resort</span> · Pool, Gym, Resto, Spa',
  'Booking Sekarang · <span class="highlight">Lock Harga 90 Hari</span>',
  'Konsultasi <span class="highlight">GRATIS</span> · Tim Profesional 24/7 di WhatsApp',
];

// ── Villa data (pakai real images dari V5.1) ──
const villaImages = {
  bijak: siteData.assets?.villa?.bijak || '/images/villa/bijak/hero-row.jpeg',
  idaman: siteData.assets?.villa?.idaman || '/images/villa/idaman/hero-row.jpeg',
  mapan: siteData.assets?.villa?.mapan || '/images/villa/mapan/hero-detail.jpeg',
};

const showcaseVillas = villaData.types.map((v) => ({
  ...v,
  image: villaImages[v.id],
}));
---

<BaseLayout>
  <NavMenu client:load variant="dark" />

  <main>
    <!-- ═══ 1. EDITORIAL HERO (V5.2: +heroFacts +micro-form) ═══ -->
    <EditorialHero
      client:load
      title={heroTitle}
      accent={heroAccent}
      eyebrow={heroEyebrow}
      badge={heroBadge}
      body={heroBody}
    />

    <!-- ═══ 1B. INLINE LEAD FORM (catch hot traffic dari Google Ads) ═══ -->
    <section class="relative bg-gradient-to-br from-forest-900 via-forest-800 to-forest-900 text-cream-50 py-14 md:py-20 overflow-hidden gsap-fade" data-section="home-lead-form">
      <!-- Decorative pattern -->
      <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background-image: radial-gradient(circle, #D4A574 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="absolute -top-20 -right-20 w-96 h-96 rounded-full blur-3xl opacity-20" style="background: radial-gradient(circle, rgba(212,165,116,0.4) 0%, transparent 70%);"></div>

      <div class="container-wide relative">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
          <div class="lg:col-span-5 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 bg-gold-500/20 text-gold-500 px-3 py-1.5 text-[10px] font-bold tracking-widest uppercase mb-4">
              <span class="w-2 h-2 bg-gold-500 rounded-full animate-pulse"></span>
              16 dari 74 unit tersisa
            </div>
            <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl text-cream-50 leading-[1.0] tracking-tight font-bold mb-5">
              Mau tau villa yang <em class="text-gold-500 font-medium">cocok untuk budget</em> Anda?
            </h2>
            <p class="font-body text-base sm:text-lg text-cream-50/80 leading-relaxed mb-6 max-w-xl mx-auto lg:mx-0">
              Tim Sahid akan kirim PDF simulasi personal via WhatsApp — cicilan, passive income, dan proyeksi 15 tahun disesuaikan dengan profil Anda. Gratis, tanpa komitmen.
            </p>
            <ul class="space-y-2 text-sm text-cream-50/85 mb-6 inline-block text-left">
              <li class="flex items-start gap-2">
                <span class="text-gold-500 mt-0.5">✓</span>
                <span>Cicilan 9,1 jt/bln (DP 30%, tenor 10 tahun)</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-500 mt-0.5">✓</span>
                <span>Passive income 9% p.a. guarantee 2 tahun</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-500 mt-0.5">✓</span>
                <span>SHM + izin komersial resort, fully furnished</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-gold-500 mt-0.5">✓</span>
                <span>Survey lokasi GRATIS shuttle dari Bandung</span>
              </li>
            </ul>
          </div>

          <div class="lg:col-span-7">
            <InlineLeadForm
              client:only="svelte"
              heading="Miliki"
              headingItalic="Unit Sekarang"
              subheading="Simulasi cicilan, passive income, dan proyeksi 15 tahun disesuaikan dengan profil Anda. Gratis, tanpa komitmen."
              source="homepage_inline_form"
              ctaText="Kirim Simulasi Personal"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 2. MARQUEE (trust badges horizontal) ═══ -->
    <Marquee client:visible items={marqueeItems} speed={60} />

    <!-- ═══ 3. CONCERNS (V5.2 NEW: port dari existing PROVEN) ═══ -->
    <ConcernsSection client:visible concerns={siteData.concerns} />

    <SectionDivider variant="ornate" pattern="dots" />

    <!-- ═══ 4. SOLUTION (V5.2 NEW: port dari existing PROVEN) ═══ -->
    <SolutionSection client:visible solutions={siteData.solutions} />

    <!-- ═══ 5. THE PROMISE (4 stat counters + 3 benefit cards) ═══ -->
    <ThePromise client:visible />

    <SectionDivider variant="diamond" pattern="grid" />

    <!-- ═══ 6. PILIHAN RESORT (V5.2 NEW: 3 VillaCard dengan label unik) ═══ -->
    <PilihanResortSection client:visible villas={showcaseVillas} />

    <!-- ═══ 7. POPULARITAS TIPE (V5.2 NEW: real-time count) ═══ -->
    <PopularitasTipeSection client:visible popularitas={siteData.popularitas} />

    <!-- ═══ 7.5 MID-PAGE CTA (re-engagement) ═══ -->
    <MidCTA
      client:visible
      eyebrow="Diskusi Personal"
      heading="Bingung pilih tipe villa?"
      subheading="Tim konsultan kami bantu rekomendasikan villa yang paling pas untuk budget & timeline Anda — gratis, tanpa komitmen."
      ctaLabel="Chat WhatsApp Sekarang"
      secondaryCtaLabel="Lihat 3 Tipe Villa"
      secondaryCtaHref="/villa"
    />

    <!-- ═══ 8. VIRTUAL TOUR 360° (V5.2 NEW: Panorama360) ═══ -->
    <VirtualTourSection
      client:visible
      src={siteData.assets?.hero360 || '/360/panorama-main.jpg'}
      poster={siteData.assets?.hero360Poster || '/360/panorama-poster.jpg'}
    />

    <SectionDivider variant="ornate" pattern="dots" />

    <!-- ═══ 9. PROMO SPESIAL (V5.2 NEW: CountdownTimer + benefit cards) ═══ -->
    <PromoSpesialSection client:visible promo={siteData.promo} />

    <!-- ═══ 10. TESTIMONI CAROUSEL (6 quotes real) ═══ -->
    <TestimoniCarousel client:visible />

    <SectionDivider variant="diamond" pattern="grid" />

    <!-- ═══ 11. FINAL CTA (V5.2 NEW: LiveActivity + Countdown + dual CTA) ═══ -->
    <FinalCTASection
      client:visible
      liveEvents={siteData.liveEvents}
      promoDeadline={siteData.promo?.deadline}
    />
  </main>

  <Footer />
</BaseLayout>
