---
/**
 * Homepage V5.2 — 11 sections, 7-ribuan px scroll
 * Setiap section punya narrative role (hook / value / proof / cta).
 * Pattern: Concerns → Solution (proven dari existing), bukan template per-section.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/astro/Footer.astro';
import SectionDivider from '../components/astro/SectionDivider.astro';
import siteData from '../data/site.json';
import villaData from '../data/villa.json';

import NavMenu from '../components/svelte/NavMenu.svelte';
import EditorialHero from '../components/svelte/EditorialHero.svelte';
import Cursor from '../components/svelte/Cursor.svelte';
import Marquee from '../components/svelte/Marquee.svelte';
import ThePromise from '../components/svelte/ThePromise.svelte';
import HowItWorks from '../components/svelte/HowItWorks.svelte';
import TestimoniCarousel from '../components/svelte/TestimoniCarousel.svelte';

// V5.2 NEW sections
import ConcernsSection from '../components/svelte/ConcernsSection.svelte';
import SolutionSection from '../components/svelte/SolutionSection.svelte';
import PilihanResortSection from '../components/svelte/PilihanResortSection.svelte';
import PopularitasTipeSection from '../components/svelte/PopularitasTipeSection.svelte';
import VirtualTourSection from '../components/svelte/VirtualTourSection.svelte';
import PromoSpesialSection from '../components/svelte/PromoSpesialSection.svelte';
import FinalCTASection from '../components/svelte/FinalCTASection.svelte';
import MidCTA from '../components/svelte/MidCTA.svelte';

// ── Hero data ──
const heroTitle = 'Masa Depan';
const heroAccent = 'Lebih Mapan.';
const heroEyebrow = '01 / Edition · 2026';
const heroBadge = 'Limited Release · 16 dari 74 unit tersisa';
const heroBody = 'Aset warisan produktif berlegalitas SHM Bersih di Cicalengka, Bandung Timur. Dikelola harian oleh Sahid Hotels & Resorts (50+ tahun). Passive income setiap bulan dari villa resort mewah.';

// ── Marquee ──
const marqueeItems = [
  'SHM Bersih',
  'Dikelola Sahid 50+ Tahun',
  'ROI 10% Guarantee',
  'Passive Income Otomatis',
  'Cicilan Mulai 9 Juta',
  'Bandung Timur',
  'Cicalengka',
  '16 dari 74 Unit Tersisa',
];

// ── Villa data (pakai real images dari V5.1) ──
const villaImages = {
  bijak: siteData.assets?.villa?.bijak || '/images/villa/bijak/hero-row.jpeg',
  idaman: siteData.assets?.villa?.idaman || '/images/villa/idaman/hero-row.jpeg',
  mapan: siteData.assets?.villa?.mapan || '/images/villa/mapan/hero-detail.jpeg',
};

const showcaseVillas = villaData.types.map((v) => ({
  ...v,
  image: villaImages[v.id],
}));
---

<BaseLayout>
  <Cursor client:load />
  <NavMenu client:load variant="dark" />

  <main>
    <!-- ═══ 1. EDITORIAL HERO (V5.2: +heroFacts +micro-form) ═══ -->
    <EditorialHero
      client:load
      title={heroTitle}
      accent={heroAccent}
      eyebrow={heroEyebrow}
      badge={heroBadge}
      body={heroBody}
    />

    <!-- ═══ 2. MARQUEE (trust badges horizontal) ═══ -->
    <Marquee client:visible items={marqueeItems} speed={35} />

    <!-- ═══ 3. CONCERNS (V5.2 NEW: port dari existing PROVEN) ═══ -->
    <ConcernsSection client:visible concerns={siteData.concerns} />

    <SectionDivider variant="ornate" pattern="dots" />

    <!-- ═══ 4. SOLUTION (V5.2 NEW: port dari existing PROVEN) ═══ -->
    <SolutionSection client:visible solutions={siteData.solutions} />

    <!-- ═══ 5. THE PROMISE (4 stat counters + 3 benefit cards) ═══ -->
    <ThePromise client:visible />

    <SectionDivider variant="diamond" pattern="grid" />

    <!-- ═══ 6. PILIHAN RESORT (V5.2 NEW: 3 VillaCard dengan label unik) ═══ -->
    <PilihanResortSection client:visible villas={showcaseVillas} />

    <!-- ═══ 7. POPULARITAS TIPE (V5.2 NEW: real-time count) ═══ -->
    <PopularitasTipeSection client:visible popularitas={siteData.popularitas} />

    <!-- ═══ 7.5 MID-PAGE CTA (re-engagement) ═══ -->
    <MidCTA
      client:visible
      eyebrow="Diskusi Personal"
      heading="Bingung pilih tipe villa?"
      subheading="Tim konsultan kami bantu rekomendasikan villa yang paling pas untuk budget & timeline Anda — gratis, tanpa komitmen."
      ctaLabel="Chat WhatsApp Sekarang"
      secondaryCtaLabel="Lihat 3 Tipe Villa"
      secondaryCtaHref="/villa"
    />

    <!-- ═══ 8. VIRTUAL TOUR 360° (V5.2 NEW: Panorama360) ═══ -->
    <VirtualTourSection
      client:visible
      src={siteData.assets?.hero360 || '/360/panorama-main.jpg'}
      poster={siteData.assets?.hero360Poster || '/360/panorama-poster.jpg'}
    />

    <SectionDivider variant="ornate" pattern="dots" />

    <!-- ═══ 9. PROMO SPESIAL (V5.2 NEW: CountdownTimer + benefit cards) ═══ -->
    <PromoSpesialSection client:visible promo={siteData.promo} />

    <!-- ═══ 10. TESTIMONI CAROUSEL (6 quotes real) ═══ -->
    <TestimoniCarousel client:visible />

    <SectionDivider variant="diamond" pattern="grid" />

    <!-- ═══ 11. FINAL CTA (V5.2 NEW: LiveActivity + Countdown + dual CTA) ═══ -->
    <FinalCTASection
      client:visible
      liveEvents={siteData.liveEvents}
      promoDeadline={siteData.promo?.deadline}
    />
  </main>

  <Footer />
</BaseLayout>
