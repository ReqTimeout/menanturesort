---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import WhatsAppFloating from '../components/astro/WhatsAppFloating.astro';
import Hero from '../components/astro/Hero.astro';
import StatsBar from '../components/astro/StatsBar.astro';
import VillaCard from '../components/astro/VillaCard.astro';
import siteData from '../data/site.json';
import villaData from '../data/villa.json';
import { formatRupiah, waUrl } from '../lib/format';

const waLink = (msg: string) => waUrl(siteData.contact.whatsapp, msg, 'homepage_cta');
---
<BaseLayout>
  <Navbar />

  <main>
    <!-- ============================================
         SECTION 1: HERO (premium, parallax, Svelte)
         ============================================ -->
    <Hero />

    <!-- ============================================
         SECTION 2: STATS BAR (animated counter)
         ============================================ -->
    <StatsBar />

    <!-- ============================================
         SECTION 3: PROBLEM → PROMISE (split layout)
         ============================================ -->
    <section class="split-section">
      <div class="split-left">
        <div class="split-sticky">
          <span class="eyebrow-gold">PUNYA VILLA IMPIAN TANPA PUSING KELOLA</span>
          <h2 class="split-title">
            Kami Tahu<br/>
            <em>Apa yang Anda<br/>K Khawatirkan</em>
          </h2>
          <p class="split-sub">
            Kebanyakan investor villa gagal bukan karena salah beli, tapi karena
            salah kelola. Kami selesaikan itu.
          </p>
        </div>
      </div>

      <div class="split-right">
        <div class="problem-card">
          <div class="problem-icon">✗</div>
          <h3 class="problem-title">Yang Biasa Terjadi</h3>
          <ul class="problem-list">
            <li><span class="x">✗</span> Cari tamu sendiri, ribet</li>
            <li><span class="x">✗</span> Maintenance bocor, AC rusak — semua tanggung jawab Anda</li>
            <li><span class="x">✗</span> Okupansi rendah, income tidak konsisten</li>
            <li><span class="x">✗</span> Aset tidak jelas (Hak Pakai, bukan SHM)</li>
            <li><span class="x">✗</span> Developer kabur, garansi tidak jelas</li>
          </ul>
        </div>

        <div class="solution-card">
          <div class="solution-icon">✓</div>
          <h3 class="solution-title">Yang Anda Dapat di Menantu</h3>
          <ul class="solution-list">
            <li><span class="check">✓</span> Tamu diurus profesional oleh tim Sahid</li>
            <li><span class="check">✓</span> Maintenance, housekeeping, operasional di-handle tim resort</li>
            <li><span class="check">✓</span> Okupansi ditarget 60-70% dengan marketing terintegrasi</li>
            <li><span class="check">✓</span> SHM atas nama pribadi, aset seumur hidup</li>
            <li><span class="check">✓</span> Developer PT Cipta Multikarya (15+ tahun track record)</li>
          </ul>
        </div>
      </div>
    </section>

    <style>
      .split-section {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        background: #F5F0E8;
        min-height: 100vh;
      }
      .split-left {
        background: #0D1B14;
        color: white;
        padding: 120px 60px;
        display: flex;
        align-items: center;
        position: sticky;
        top: 0;
        height: 100vh;
      }
      .split-sticky { max-width: 480px; }
      .eyebrow-gold {
        display: inline-block;
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #D4A574;
        margin-bottom: 32px;
      }
      .split-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 1.05;
        color: white;
        margin: 0 0 32px;
        text-wrap: balance;
      }
      .split-title em {
        color: #D4A574;
        font-style: italic;
        font-weight: 400;
      }
      .split-sub {
        font-family: 'Inter', sans-serif;
        font-size: 17px;
        line-height: 1.7;
        color: rgba(255,255,255,0.8);
        margin: 0;
      }
      .split-right {
        padding: 120px 60px;
        display: flex;
        flex-direction: column;
        gap: 32px;
        align-items: stretch;
      }
      .problem-card, .solution-card {
        padding: 48px;
        position: relative;
        overflow: hidden;
      }
      .problem-card {
        background: white;
        border-left: 4px solid #DC2626;
      }
      .solution-card {
        background: #1B4332;
        color: white;
        border-left: 4px solid #D4A574;
      }
      .problem-icon, .solution-icon {
        font-family: 'Playfair Display', serif;
        font-size: 5rem;
        font-weight: 700;
        line-height: 1;
        margin-bottom: 16px;
      }
      .problem-icon { color: #DC2626; }
      .solution-icon { color: #D4A574; }
      .problem-title, .solution-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 32px;
      }
      .problem-title { color: #0D1B14; }
      .solution-title { color: white; }
      .problem-list, .solution-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .problem-list li, .solution-list li {
        font-family: 'Inter', sans-serif;
        font-size: 15px;
        line-height: 1.6;
        display: flex;
        gap: 12px;
        align-items: flex-start;
      }
      .problem-list li { color: #4B5563; }
      .solution-list li { color: rgba(255,255,255,0.9); }
      .x { color: #DC2626; font-weight: 700; flex-shrink: 0; }
      .check { color: #D4A574; font-weight: 700; flex-shrink: 0; }
      @media (max-width: 1024px) {
        .split-section { grid-template-columns: 1fr; }
        .split-left { position: relative; height: auto; padding: 80px 24px; }
        .split-right { padding: 60px 24px; }
        .problem-card, .solution-card { padding: 32px 24px; }
      }
    </style>

    <!-- ============================================
         SECTION 4: TIPE VILLA (premium cards)
         ============================================ -->
    <section id="villa-types" class="villa-section">
      <div class="container">
        <div class="villa-section-header">
          <span class="eyebrow-gold">PILIH VILLA ANDA</span>
          <h2 class="villa-section-title">
            3 Tipe Villa,<br/>
            <em>Semua dengan SHM</em>
          </h2>
          <p class="villa-section-sub">
            Dari entry-level untuk first-time investor hingga flagship premium.
            Semua dengan sertifikat Hak Milik atas nama pribadi.
          </p>
        </div>

        <div class="villa-grid">
          {villaData.types.map((villa, i) => (
            <VillaCard villa={villa} index={i} />
          ))}
        </div>
      </div>
    </section>

    <style>
      .villa-section {
        padding: 140px 0;
        background: white;
        position: relative;
      }
      .villa-section::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent 0%, #D4A574 50%, transparent 100%);
      }
      .villa-section-header {
        text-align: center;
        max-width: 720px;
        margin: 0 auto 80px;
      }
      .villa-section-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        line-height: 1.1;
        color: #0D1B14;
        margin: 24px 0 24px;
        text-wrap: balance;
      }
      .villa-section-title em {
        color: #1B4332;
        font-style: italic;
        font-weight: 400;
      }
      .villa-section-sub {
        font-family: 'Inter', sans-serif;
        font-size: 17px;
        line-height: 1.6;
        color: #4B5563;
        margin: 0;
      }
      .villa-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border-left: 1px solid #E5E7EB;
      }
      @media (max-width: 1024px) {
        .villa-section { padding: 80px 0; }
        .villa-grid { grid-template-columns: 1fr; border-left: none; }
      }
    </style>

    <!-- ============================================
         SECTION 5: PASSIVE INCOME CHART
         ============================================ -->
    <section class="chart-section">
      <div class="chart-bg"></div>
      <div class="container">
        <div class="chart-header">
          <span class="eyebrow-gold">CICILAN ANDA, DITUTUP INCOME ANDA</span>
          <h2 class="chart-title">
            Bayangkan:<br/>
            <em>Villa Anda Membayar</em><br/>
            Cicilannya Sendiri.
          </h2>
          <p class="chart-sub">
            Okupansi 50%, tarif Rp 2,2 juta/malam. Cicilan 15 tahun ke bank.
            Income yang masuk dari villa: Cukup. Untuk. Menutup. Cicilan.
          </p>
        </div>

        <div class="chart-grid">
          {villaData.types.map((villa, i) => {
            const maxBar = 16000000; // 16jt
            const cicilanPct = (villa.cicilanBank / maxBar) * 100;
            const incomePct = (villa.passiveIncome / maxBar) * 100;
            return (
              <div class="chart-item" style={`--i: ${i}`}>
                <div class="chart-item-header">
                  <h3>{villa.name}</h3>
                  <span class={`status ${villa.surplusBank > 0 ? 'positive' : 'negative'}`}>
                    {villa.surplusBank > 0 ? '✓ Cicilan tertutup' : '⚠ Defisit'}
                  </span>
                </div>
                <div class="bar-group">
                  <div class="bar-label">
                    <span>Cicilan</span>
                    <span class="bar-value">{formatRupiah(villa.cicilanBank)}</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill bar-cicilan" style={`width: ${cicilanPct}%`}></div>
                  </div>
                </div>
                <div class="bar-group">
                  <div class="bar-label">
                    <span>Passive Income</span>
                    <span class="bar-value gold">{formatRupiah(villa.passiveIncome)}</span>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill bar-income" style={`width: ${incomePct}%`}></div>
                  </div>
                </div>
                <div class="chart-item-footer">
                  <span class="footer-label">Surplus per bulan</span>
                  <span class={`footer-value ${villa.surplusBank > 0 ? 'positive' : 'negative'}`}>
                    {villa.surplusBank > 0 ? '+' : ''}{formatRupiah(villa.surplusBank)}
                  </span>
                </div>
              </div>
            );
          })}
        </div>

        <p class="chart-disclaimer">
          *Simulasi berdasarkan okupansi 50% & tarif Rp 2,2jt/malam. Performa aktual dapat bervariasi.
        </p>

        <div class="chart-cta">
          <a href="/investasi/simulasi-kpr" class="btn-premium btn-primary-premium">
            <span>Hitung Sendiri di Simulator</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <style>
      .chart-section {
        background: #0D1B14;
        padding: 140px 0;
        position: relative;
        overflow: hidden;
      }
      .chart-bg {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 40% at 30% 20%, rgba(27, 67, 50, 0.4) 0%, transparent 60%),
          radial-gradient(ellipse 50% 30% at 80% 80%, rgba(212, 165, 116, 0.1) 0%, transparent 60%);
      }
      .chart-header { text-align: center; max-width: 800px; margin: 0 auto 80px; position: relative; }
      .chart-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        font-weight: 700;
        line-height: 1.05;
        color: white;
        margin: 24px 0 24px;
        text-wrap: balance;
      }
      .chart-title em { color: #D4A574; font-style: italic; font-weight: 400; }
      .chart-sub {
        font-family: 'Inter', sans-serif;
        font-size: 17px;
        line-height: 1.7;
        color: rgba(255,255,255,0.7);
        margin: 0;
      }
      .chart-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-bottom: 32px;
        position: relative;
      }
      .chart-item {
        background: rgba(255,255,255,0.04);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(212, 165, 116, 0.2);
        padding: 32px;
        animation: chartFade 0.8s ease-out calc(var(--i) * 0.15s) both;
      }
      @keyframes chartFade {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .chart-item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(212, 165, 116, 0.15);
      }
      .chart-item-header h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
        margin: 0;
      }
      .status {
        font-family: 'Inter', sans-serif;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 2px;
      }
      .status.positive { background: rgba(22, 163, 74, 0.15); color: #4ADE80; }
      .status.negative { background: rgba(220, 38, 38, 0.15); color: #F87171; }

      .bar-group { margin-bottom: 20px; }
      .bar-label {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 8px;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: rgba(255,255,255,0.6);
      }
      .bar-value { color: white; font-weight: 600; font-variant-numeric: tabular-nums; }
      .bar-value.gold { color: #D4A574; }

      .bar-track {
        height: 6px;
        background: rgba(255,255,255,0.08);
        overflow: hidden;
      }
      .bar-fill {
        height: 100%;
        transform-origin: left;
        animation: barGrow 1.5s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i) * 0.15s + 0.3s) both;
      }
      @keyframes barGrow {
        from { transform: scaleX(0); }
        to { transform: scaleX(1); }
      }
      .bar-cicilan { background: linear-gradient(90deg, #DC2626 0%, #F59E0B 100%); }
      .bar-income { background: linear-gradient(90deg, #D4A574 0%, #16A34A 100%); }

      .chart-item-footer {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid rgba(212, 165, 116, 0.15);
        font-family: 'Inter', sans-serif;
      }
      .footer-label { font-size: 12px; color: rgba(255,255,255,0.6); }
      .footer-value { font-size: 1.25rem; font-weight: 700; font-variant-numeric: tabular-nums; }
      .footer-value.positive { color: #4ADE80; }
      .footer-value.negative { color: #F87171; }

      .chart-disclaimer {
        text-align: center;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        margin: 0 0 40px;
        position: relative;
      }
      .chart-cta { text-align: center; position: relative; }

      @media (max-width: 1024px) {
        .chart-section { padding: 80px 0; }
        .chart-grid { grid-template-columns: 1fr; }
      }
    </style>

    <!-- ============================================
         SECTION 6: FINAL CTA
         ============================================ -->
    <section class="final-cta-section">
      <div class="container">
        <div class="urgency-badge">
          <span class="pulse"></span>
          PERHATIAN: HARGA NAIK Q3 2026
        </div>
        <h2 class="final-cta-title">
          58 dari 74 unit sudah terjual.<br/>
          <em class="gold">Sisa 16 unit.</em><br/>
          Booking fee Rp 10 juta<br/>
          <span class="small">lock harga hari ini.</span>
        </h2>
        <div class="final-cta-buttons">
          <a href={waLink('Halo, saya tertarik booking unit Menantu Resort')} target="_blank" rel="noopener" class="btn-premium btn-wa-premium btn-premium-lg">
            💬 Chat WhatsApp Sekarang
          </a>
          <a href="/kontak" class="btn-premium btn-outline-premium btn-premium-lg">
            📅 Jadwalkan Kunjungan
          </a>
        </div>
        <p class="final-cta-trust">✅ Pembayaran ke rekening PT Cipta Multikarya Propertindo · Booking fee 100% refundable</p>
      </div>
    </section>

    <style>
      .final-cta-section {
        background: #0D1B14;
        padding: 140px 0;
        text-align: center;
        position: relative;
        overflow: hidden;
      }
      .final-cta-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(212, 165, 116, 0.08) 0%, transparent 60%);
      }
      .urgency-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(220, 38, 38, 0.15);
        border: 1px solid rgba(220, 38, 38, 0.3);
        padding: 10px 20px;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #FCA5A5;
        margin-bottom: 40px;
        position: relative;
      }
      .pulse {
        width: 8px;
        height: 8px;
        background: #DC2626;
        border-radius: 50%;
        animation: pulseDot 1.5s ease-in-out infinite;
      }
      @keyframes pulseDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.5); }
      }
      .final-cta-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 6vw, 5rem);
        font-weight: 700;
        line-height: 1.05;
        color: white;
        margin: 0 auto 48px;
        max-width: 900px;
        text-wrap: balance;
        position: relative;
      }
      .final-cta-title em { color: #D4A574; font-style: italic; font-weight: 400; }
      .final-cta-title em.gold { color: #D4A574; }
      .final-cta-title .small {
        font-size: 0.6em;
        color: rgba(255,255,255,0.7);
        font-weight: 400;
        font-family: 'Inter', sans-serif;
      }
      .final-cta-buttons {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 40px;
        position: relative;
      }
      .btn-premium-lg { padding: 20px 40px; font-size: 15px; }
      .btn-outline-premium {
        background: transparent;
        color: white;
        border-color: rgba(255,255,255,0.3);
      }
      .btn-outline-premium:hover {
        background: white;
        color: #0D1B14;
        border-color: white;
      }
      .final-cta-trust {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        color: rgba(255,255,255,0.5);
        margin: 0;
        position: relative;
      }
      @media (max-width: 768px) {
        .final-cta-section { padding: 80px 0; }
        .final-cta-buttons { flex-direction: column; }
        .btn-premium-lg { width: 100%; }
      }
    </style>
  </main>

  <Footer />
  <WhatsAppFloating />
</BaseLayout>
