---
/**
 * /villa/idaman — Halaman detail Menantu Idaman (V5.2)
 * Template: VillaDetail.astro
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import NavMenu from '../../components/svelte/NavMenu.svelte';
import UrgencyBanner from '../../components/svelte/UrgencyBanner.svelte';
import Footer from '../../components/astro/Footer.astro';
import VillaDetail from '../../components/astro/VillaDetail.astro';
import villaData from '../../data/villa.json';
import siteData from '../../data/site.json';

const villa = villaData.types.find((v) => v.id === 'idaman');

// Interior images untuk Idaman — 5 foto
const interiorImages = [
  '/images/villa/idaman/hero-row.jpeg',
  '/images/interior/hero/kitchen-sink.jpg',
  '/images/interior/hero/bathroom-bathtub.jpg',
  '/images/interior/hero/stairs-cream.jpg',
  '/images/interior/hero/bathroom-bathtub.jpg',
];

if (!villa) throw new Error('Villa idaman tidak ditemukan di data');
---

<BaseLayout
  title={`${villa.name} — Best Value Rp 1,6 Miliar | Menantu Resort`}
  description={`${villa.tagline}. ${villa.lb}m² / ${villa.lt}m², ${villa.bedrooms} kamar, double glass façade. Best value villa, SHM, dikelola Sahid, ROI 10% p.a. Cicilan Rp 11,6 jt/bln.`}
  ogImage={villa.image}
>
  <NavMenu client:load />

  <main class="pt-20">
    <UrgencyBanner client:visible unitsLeft={12} totalUnits={36} />

    <VillaDetail
      villa={villa}
      interiorImages={interiorImages}
      accentColor="idaman"
    />
  </main>

  <Footer />
</BaseLayout>
