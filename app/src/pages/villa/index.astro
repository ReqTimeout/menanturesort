---
/**
 * /villa — Landing page villa overview (V5.2)
 *
 * 7 sections:
 *   1. EditorialHero    — "Anda tidak sedang membeli villa..."
 *   2. UrgencyBanner    — 16 dari 74 unit tersisa
 *   3. VillaCardGrid    — 3 VillaCard dengan label unik (Attic / Double Glass / Luxury Private)
 *   4. VillaComparisonTable — side-by-side comparison
 *   5. ROISimulator     — interactive KPR + passive income
 *   6. TestimoniStories — 3 cerita investor
 *   7. FinalCTASection  — urgency + dual CTA
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import NavMenu from '../../components/svelte/NavMenu.svelte';
import UrgencyBanner from '../../components/svelte/UrgencyBanner.svelte';
import VillaCard from '../../components/svelte/VillaCard.svelte';
import VillaComparisonTable from '../../components/svelte/VillaComparisonTable.svelte';
import ROISimulator from '../../components/svelte/ROISimulator.svelte';
import TestimoniStories from '../../components/svelte/TestimoniStories.svelte';
import FinalCTASection from '../../components/svelte/FinalCTASection.svelte';
import Footer from '../../components/astro/Footer.astro';
import SectionDivider from '../../components/astro/SectionDivider.astro';
import Pattern from '../../components/astro/Pattern.astro';
import SectionBackground from '../../components/astro/SectionBackground.astro';
import { waUrl, formatRupiah, formatShort } from '@lib/utils';
import { ArrowRight, Sparkles, MapPin, Shield, TrendingUp, Home, Award, Building2 } from 'lucide-svelte';
import villaData from '../../data/villa.json';
import siteData from '../../data/site.json';

const types = villaData.types || [];
const villaColorMap = {
  bijak: { bg: '#F5F0E8', text: '#0D1B14', border: '#D4A574' },
  idaman: { bg: '#D4A574', text: '#0D1B14', border: '#A8845C' },
  mapan: { bg: '#0D1B14', text: '#D4A574', border: '#D4A574' },
};
const totalUnits = siteData.stats.totalUnits;
const unitsLeft = totalUnits - siteData.stats.unitsSold;
---

<BaseLayout
  title="Pilih Vila Impian — 3 Tipe Premium | Menantu Resort Bandung"
  description="Bandingkan 3 tipe villa premium di Cicalengka, Bandung Timur: Bijak (1,2 M / Attic), Idaman (1,6 M / Double Glass), Mapan (2 M / Luxury Private). Semua SHM, dikelola Sahid 50+ tahun, ROI 10% p.a. guarantee."
>
  <NavMenu client:load />

  <main class="pt-20">
    <!-- 1. Editorial Hero -->
    <section class="reveal relative bg-cream-50 overflow-hidden" data-section="hero">
      <div class="absolute inset-0 bg-gradient-to-b from-cream-50 via-cream-100/30 to-cream-50"></div>

      
    <Pattern variant="dots" color="forest" opacity={0.05} />
    <div class="container-wide relative py-12 md:py-20">
        <div class="grid grid-cols-12 gap-8 lg:gap-12 items-center">
          <div class="col-span-12 lg:col-span-7">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-4">— Villa · Edition 2026</div>
            <h1 class="font-display text-forest-700 leading-[1.1] sm:leading-[0.95] tracking-tight text-[1.5rem] sm:text-editorial-xl font-bold mb-4 sm:mb-8" style="text-shadow: 0 1px 0 rgba(245,240,232,0.4);">
              Anda tidak sedang<br/>
              <em class="text-gold-700">membeli villa.</em><br/>
              Anda sedang memilih<br/>
              <em class="text-gold-700">gaya hidup 30 tahun ke depan.</em>
            </h1>
            <p class="font-body text-sm sm:text-base md:text-lg text-ink-500 leading-relaxed mb-6 sm:mb-10 max-w-xl">
              Setiap villa di sini dirancang untuk satu hal: <strong class="text-forest-700">passive income yang konsisten, aset yang terus naik, dan warisan yang bisa diwariskan.</strong> Bukan spekulasi. Bukan wangsit. Ini real estat dengan brand yang sudah 50+ tahun terbukti.
            </p>

            <div class="flex flex-wrap gap-3">
              <a href="#villa-grid" class="btn btn-primary btn-lg">
                Bandingkan 3 Villa
                <ArrowRight size={16} />
              </a>
              <a href={waUrl(siteData.contact.whatsapp, 'Halo, saya mau diskusi pilihan villa yang tepat untuk budget saya.', 'villa_index_konsultasi')} class="btn btn-outline btn-lg">
                Konsultasi Gratis
              </a>
            </div>

            <!-- Trust bar -->
            <div class="grid grid-cols-3 gap-6 mt-12 pt-8 border-t border-forest-700/10">
              <div>
                <div class="font-display text-3xl text-forest-700">{siteData.stats.unitsSold}/{totalUnits}</div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mt-1">Unit Terjual</div>
              </div>
              <div>
                <div class="font-display text-3xl text-forest-700">Rp 1,2 M</div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mt-1">Mulai dari</div>
              </div>
              <div>
                <div class="font-display text-3xl text-forest-700">10% p.a.</div>
                <div class="text-xs text-ink-mute uppercase tracking-wider mt-1">ROI Guarantee</div>
              </div>
            </div>
          </div>

          <!-- Right: 3 mini cards stack -->
          <div class="col-span-12 lg:col-span-5">
            <div class="space-y-4">
              {types.map((v, i) => (
                <a
                  href={`/villa/${v.id}`}
                  class="card-premium block p-5 hover:scale-[1.02] transition-transform"
                >
                  <div class="flex items-start gap-4">
                    <div class="w-16 h-16 bg-forest-700 text-gold-500 flex items-center justify-center flex-shrink-0">
                      <span class="font-display text-2xl">{String(i + 1).padStart(2, '0')}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="inline-block px-2.5 py-1 text-xs font-mono uppercase tracking-wider font-semibold" style={`background-color: ${villaColorMap[v.id].bg}; color: ${villaColorMap[v.id].text}; border: 1px solid ${villaColorMap[v.id].border};`}>{v.label}</span>
                        <span class="text-xs text-ink-mute">{v.lb}m² · {v.bedrooms}BR</span>
                      </div>
                      <h3 class="font-display text-xl text-forest-700 mb-1">{v.name}</h3>
                      <p class="text-sm text-ink-soft line-clamp-1">{v.tagline}</p>
                      <div class="flex items-center justify-between mt-3">
                        <span class="font-display text-lg text-forest-700">{v.priceDisplay}</span>
                        <ArrowRight class="w-4 h-4 text-gold-700" />
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. Urgency Banner -->
    <UrgencyBanner client:visible unitsLeft={unitsLeft} totalUnits={totalUnits} />

    <SectionDivider variant="ornate" />

    <!-- 3. Villa Card Grid -->
    <section id="villa-grid" class="bg-white py-14 md:py-24 gsap-fade" reveal data-section="villa-grid">
    <SectionBackground variant="cream" pattern={true} orbs={true} intensity="subtle" />
      
    <Pattern variant="grid" color="forest" opacity={0.05} />
    <div class="container-wide">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— Pilihan Villa</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight">
              Tiga karakter, satu <em class="text-gold-700">standar Sahid</em>
            </h2>
            <p class="font-body text-lg text-ink-soft mt-4 max-w-2xl">
              Pilih yang sesuai dengan budget, gaya hidup, dan target passive income Anda.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {types.map((villa) => (
            <VillaCard
              client:load
              villa={villa}
            />
          ))}
        </div>
      </div>
    </section>

    <SectionDivider variant="diamond" />

    <!-- 4. Comparison Table -->
    <VillaComparisonTable client:load />

    <!-- 5. ROI Simulator -->
    <section class="relative section-cream py-14 md:py-24 gsap-fade" reveal data-section="roi">
    <SectionBackground variant="forest" pattern={true} orbs={true} intensity="subtle" />
      
    <Pattern variant="gold-sparkle" color="gold" opacity={0.07} />
    <div class="container-wide">
        <div class="grid grid-cols-12 gap-8 mb-12">
          <div class="col-span-12 md:col-span-3">
            <div class="font-mono text-xs uppercase tracking-widest text-gold-700 mb-3">— Simulasi</div>
          </div>
          <div class="col-span-12 md:col-span-9">
            <h2 class="font-display text-display-md text-forest-700 leading-[0.95] tracking-tight">
              Hitung sendiri <em class="text-gold-700">passive income</em> Anda
            </h2>
            <p class="font-body text-lg text-ink-soft mt-4 max-w-2xl">
              Geser slider untuk menyesuaikan okupansi dan harga. Lihat cashflow real-time.
            </p>
          </div>
        </div>

        <ROISimulator client:load />
      </div>
    </section>

    <SectionDivider variant="ornate" />

    <!-- 6. Testimoni Stories -->
    <TestimoniStories client:load />

    <!-- 7. Final CTA -->
    <FinalCTASection client:load />
  </main>

  <Footer />
</BaseLayout>
