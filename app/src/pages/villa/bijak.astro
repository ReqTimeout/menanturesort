---
/**
 * /villa/bijak — Halaman detail Menantu Bijak (V5.2)
 * Template: VillaDetail.astro
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import NavMenu from '../../components/svelte/NavMenu.svelte';
import UrgencyBanner from '../../components/svelte/UrgencyBanner.svelte';
import Footer from '../../components/astro/Footer.astro';
import VillaDetail from '../../components/astro/VillaDetail.astro';
import villaData from '../../data/villa.json';
import siteData from '../../data/site.json';

const villa = villaData.types.find((v) => v.id === 'bijak');

// Interior images untuk Bijak — 5 foto (1 hero + 4 interior)
const interiorImages = [
  '/images/villa/bijak/hero-row.jpeg',
  '/images/interior/hero/stairs-cream.jpg',
  '/images/interior/hero/bathroom-bathtub.jpg',
  '/images/interior/hero/kitchen-sink.jpg',
  '/images/interior/hero/stairs-cream.jpg',
];

if (!villa) throw new Error('Villa bijak tidak ditemukan di data');
---

<BaseLayout
  title={`${villa.name} — Mulai Rp 1,2 Miliar | Menantu Resort`}
  description={`${villa.tagline}. ${villa.lb}m² / ${villa.lt}m², ${villa.bedrooms} kamar, atap Limasan ikonik. SHM, dikelola Sahid, ROI 10% p.a. Cicilan mulai Rp 9,7 jt/bln.`}
  ogImage={villa.image}
>
  <NavMenu client:load />

  <main class="pt-20">
    <UrgencyBanner client:visible unitsLeft={16} totalUnits={36} />

    <VillaDetail
      villa={villa}
      interiorImages={interiorImages}
      accentColor="bijak"
    />
  </main>

  <Footer />
</BaseLayout>
