---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/astro/Footer.astro';
import siteData from '../../data/site.json';
import villaData from '../../data/villa.json';
import { formatShort, waUrl } from '@lib/utils';
import { ArrowRight, MessageCircle, Bed, Bath, Maximize, Square, FileCheck, TreePine, Waves, Mountain, Home, Star, Check, Shield, Award, TrendingUp, MapPin, Sparkles } from 'lucide-svelte';
import NavMenu from '../../components/svelte/NavMenu.svelte';
import VillaHero from '../../components/svelte/VillaHero.svelte';
import FloatingActionButton from '../../components/svelte/FloatingActionButton.svelte';

const villa = villaData.types.find((v) => v.id === 'bijak');
const otherVillas = villaData.types.filter((v) => v.id !== 'bijak');
const waLink = (msg) => waUrl(siteData.contact.whatsapp, msg, `villa_bijak_detail`);
const surplus = villa.passiveIncome - villa.cicilanBank;

const villaImages = [
  '/images/ref/villa-bijak-row.jpg',
  '/images/ref/interior-living.jpg',
];
const villaBadges = [
  { value: '2', label: 'Lantai' },
  { value: `${villa.lb}m²`, label: 'Bangunan' },
  { value: `${villa.lt}m²`, label: 'Tanah' },
];
---

<BaseLayout title={`${villa.name} — ${villa.tagline}`} description={`${villa.name} Menantu Resort Cicalengka: ${villa.lb}m², ${villa.bedrooms}KT, ${villa.priceDisplay}. SHM bersih, dikelola Sahid.`} type="article">
  <NavMenu client:load />
  <main class="pt-20">
    <VillaHero client:load villa={villa} images={villaImages} badges={villaBadges} />

    <!-- SPECS BAR -->
    <section class="bg-white border-y border-cream-100 py-10">
      <div class="container-wide">
        <div class="grid grid-cols-2 md:grid-cols-6 gap-6">
          {[
            { icon: 'Bed', value: villa.bedrooms, label: 'Kamar Tidur' },
            { icon: 'Bath', value: villa.bathrooms, label: 'Kamar Mandi' },
            { icon: 'Maximize', value: `${villa.lb}m²`, label: 'Bangunan' },
            { icon: 'Square', value: `${villa.lt}m²`, label: 'Tanah' },
            { icon: 'Home', value: villa.floors, label: 'Lantai' },
            { icon: 'Shield', value: 'SHM', label: 'Sertifikat' },
          ].map((s) => (
            <div class="flex flex-col items-center text-center">
              <div class="w-10 h-10 border border-gold-500/30 bg-gold-500/10 flex items-center justify-center mb-2">
                {s.icon === 'Bed' && <Bed size={18} class="text-gold-500" />}
                {s.icon === 'Bath' && <Bath size={18} class="text-gold-500" />}
                {s.icon === 'Maximize' && <Maximize size={18} class="text-gold-500" />}
                {s.icon === 'Square' && <Square size={18} class="text-gold-500" />}
                {s.icon === 'Home' && <Home size={18} class="text-gold-500" />}
                {s.icon === 'Shield' && <Shield size={18} class="text-gold-500" />}
              </div>
              <div class="font-display text-xl text-forest-700 font-bold">{s.value}</div>
              <div class="font-body text-[10px] text-ink-500 uppercase tracking-wider mt-1">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- NARRATIVE STORY -->
    <section class="section section-white">
      <div class="container-tight">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="h-px w-12 bg-gold-500"></span>
            <span class="eyebrow">Filosofi Vila</span>
            <span class="h-px w-12 bg-gold-500"></span>
          </div>
          <h2 class="font-display text-display text-forest-700 leading-[1.05] mb-6">
            Arsitektur <em>Limbung</em> Tradisional,<br/>Sentuhan <em>Modern.</em>
          </h2>
          <p class="font-quote italic text-2xl text-ink-500 leading-relaxed max-w-3xl mx-auto">
            "Menantu Bijak adalah pintu masuk Anda ke dunia properti premium. Atap Limasan etnik Jawa yang ikonik, dipadu desain interior kontemporer yang terang, lapang, dan breathable."
          </p>
        </div>

        <div class="prose prose-lg max-w-3xl mx-auto font-body text-ink-500 leading-relaxed space-y-6">
          <p>
            Vila tipe Bijak dirancang untuk Anda yang ingin memulai perjalanan investasi properti premium tanpa membebani cashflow. Dengan luas bangunan {villa.lb}m² di atas lahan {villa.lt}m², vila dua lantai ini mengadopsi arsitektur <strong class="text-forest-700">Jawa Limasan</strong> — atap tajug bersusun empat yang menyimbolkan keseimbangan dan harmoni.
          </p>
          <p>
            Ciri khasnya: void di tengah yang memungkinkan cahaya alami masuk ke jantung rumah, sirkulasi udara silang yang natural, dan balkon lantai dua menghadap kawasan resort. Material lokal premium: kayu jati untuk kisi, batu alam untuk dinding aksen, dan kaca tempered besar untuk jendela.
          </p>
          <p>
            Dikelola harian oleh tim <strong class="text-forest-700">Sahid Hotels & Resorts</strong> dengan standar hospitality bintang 5. Anda terima passive income, tanpa pusing maintenance, tanpa pusing cari tamu.
          </p>
        </div>

        <!-- Features grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-16 max-w-3xl mx-auto">
          {villa.features.map((f) => (
            <div class="flex items-start gap-3 p-4 bg-cream-50 border border-cream-100">
              <Check size={18} class="text-gold-500 mt-0.5 flex-shrink-0" strokeWidth={2.5} />
              <span class="font-body text-forest-700">{f}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- SIMULASI -->
    <section class="section section-cream">
      <div class="container-tight">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="h-px w-12 bg-gold-500"></span>
            <span class="eyebrow">Simulasi Cashflow</span>
            <span class="h-px w-12 bg-gold-500"></span>
          </div>
          <h2 class="font-display text-display text-forest-700 leading-[1.05] mb-6">
            {villa.name}, <em>dirancang cashflow positif.</em>
          </h2>
        </div>

        <div class="bg-white border border-cream-100 p-8 md:p-12">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <div class="text-center md:text-left">
              <div class="font-body text-xs text-ink-500 uppercase tracking-wider mb-2">Cicilan / Bulan</div>
              <div class="font-display text-3xl md:text-4xl text-forest-700 font-bold">{formatShort(villa.cicilanBank)}</div>
              <div class="font-body text-xs text-ink-500 mt-1">KPR Bank · 15 thn · 5%</div>
            </div>
            <div class="text-center md:text-left">
              <div class="font-body text-xs text-ink-500 uppercase tracking-wider mb-2">Passive Income</div>
              <div class="font-display text-3xl md:text-4xl text-gold-700 font-bold">{formatShort(villa.passiveIncome)}</div>
              <div class="font-body text-xs text-ink-500 mt-1">Okupansi 50% (konservatif)</div>
            </div>
            <div class="text-center md:text-left">
              <div class="font-body text-xs text-ink-500 uppercase tracking-wider mb-2">Surplus / Bulan</div>
              <div class="font-display text-3xl md:text-4xl text-whatsapp font-bold">+{formatShort(surplus)}</div>
              <div class="font-body text-xs text-ink-500 mt-1">Cashflow positif dari hari 1</div>
            </div>
          </div>

          <div class="pt-8 border-t border-cream-100">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div>
                <div class="font-body text-sm text-ink-500">Booking fee untuk mengunci unit</div>
                <div class="font-display text-2xl text-forest-700 font-bold">Rp 10 juta (refundable 30 hari)</div>
              </div>
              <a href={waLink(`Halo, saya tertarik dengan ${villa.name}. Bisa info detail simulasi?`)} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
                <MessageCircle size={18} />
                Tanya Detail via WA
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OTHER VILLAS -->
    <section class="section section-white">
      <div class="container-wide">
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="h-px w-12 bg-gold-500"></span>
            <span class="eyebrow">Tipe Lainnya</span>
            <span class="h-px w-12 bg-gold-500"></span>
          </div>
          <h2 class="font-display text-display text-forest-700 leading-[1.05]">
            Atau pilih <em>villa</em> dengan karakter berbeda.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {otherVillas.map((v) => (
            <a href={`/villa/${v.id}`} class="group relative block bg-white border border-cream-100 overflow-hidden transition-all duration-500 hover:border-gold-300 hover:shadow-xl">
              <div class="aspect-[16/9] overflow-hidden">
                <img src={v.id === 'idaman' ? '/images/ref/villa-idaman-row.jpg' : '/images/ref/villa-mapan-street.jpg'} alt={v.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="p-6">
                <div class="font-body text-xs text-ink-500 uppercase tracking-wider mb-1">{v.taglineShort}</div>
                <h3 class="font-display text-2xl text-forest-700 font-bold mb-2 group-hover:text-gold-700 transition-colors">{v.name}</h3>
                <p class="font-quote italic text-ink-500 mb-4">"{v.tagline}"</p>
                <div class="flex items-center justify-between">
                  <span class="font-mono text-lg text-forest-700 font-bold">{v.priceDisplay}</span>
                  <span class="inline-flex items-center gap-2 text-forest-700 font-body font-semibold text-sm group-hover:text-gold-700 transition-colors">
                    Detail <ArrowRight size={16} class="transition-transform group-hover:translate-x-1" />
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <FloatingActionButton client:load />
</BaseLayout>
