---
/**
 * /villa/mapan — Halaman detail Menantu Mapan (V5.2)
 * Template: VillaDetail.astro
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import NavMenu from '../../components/svelte/NavMenu.svelte';
import UrgencyBanner from '../../components/svelte/UrgencyBanner.svelte';
import Footer from '../../components/astro/Footer.astro';
import VillaDetail from '../../components/astro/VillaDetail.astro';
import villaData from '../../data/villa.json';
import siteData from '../../data/site.json';

const villa = villaData.types.find((v) => v.id === 'mapan');

// Interior images untuk Mapan — 5 foto (2 hero eksternal + 3 interior)
const interiorImages = [
  '/images/villa/mapan/hero-detail.jpeg',
  '/images/villa/mapan/street-view.jpeg',
  '/images/interior/hero/stairs-cream.jpg',
  '/images/interior/hero/bathroom-bathtub.jpg',
  '/images/interior/hero/kitchen-sink.jpg',
];

if (!villa) throw new Error('Villa mapan tidak ditemukan di data');
---

<BaseLayout
  title={`${villa.name} — Flagship Rp 2 Miliar | Menantu Resort`}
  description={`${villa.tagline}. ${villa.lb}m² / ${villa.lt}m², ${villa.bedrooms} kamar, sky deck, infinity balcony. Villa flagship tertinggi, SHM, ROI 10% p.a. Cicilan Rp 14,6 jt/bln.`}
  ogImage={villa.image}
>
  <NavMenu client:load />

  <main class="pt-20">
    <UrgencyBanner client:visible unitsLeft={2} totalUnits={2} />

    <VillaDetail
      villa={villa}
      interiorImages={interiorImages}
      accentColor="mapan"
    />
  </main>

  <Footer />
</BaseLayout>
