---
import Counter from '../svelte/Counter.svelte';
import siteData from '../../data/site.json';

const stats = [
  { value: siteData.stats.totalUnits, suffix: '', label: 'Unit Villa', sublabel: 'Total Keseluruhan', decimals: 0 },
  { value: 9, suffix: '-15 jt', label: 'Passive Income', sublabel: 'Per Bulan', decimals: 0, isRange: true },
  { value: 15, suffix: '-30%', label: 'Capital Gain', sublabel: 'Proyeksi 15 Tahun', decimals: 0, isRange: true },
  { value: 50, suffix: '+', label: 'Tahun', sublabel: 'Track Record Sahid', decimals: 0 },
];
---
<section class="stats-section">
  <div class="container">
    <div class="stats-header">
      <span class="eyebrow-gold">ANGKA YANG TIDAK BOHONG</span>
      <h2 class="stats-title">
        Mengapa 58 Investor Sudah<br/>
        <em>Memilih Menantu Resort</em>
      </h2>
    </div>

    <div class="stats-grid">
      {stats.map((stat, i) => (
        <div class="stat-item">
          <div class="stat-number">
            {stat.isRange ? (
              <span class="stat-counter">
                {stat.value}<span class="stat-suffix">-{i === 1 ? '15' : '30'}{stat.suffix.replace(/^\d+-/, '').replace(' jt', '').replace('%', '')}<span class="stat-suffix-small">{stat.suffix.includes('jt') ? ' jt' : '%'}</span></span>
              </span>
            ) : (
              <Counter client:visible target={stat.value} suffix={stat.suffix} />
            )}
          </div>
          <div class="stat-divider"></div>
          <div class="stat-label">{stat.label}</div>
          <div class="stat-sublabel">{stat.sublabel}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-section {
    background: #0D1B14;
    color: #FFFFFF;
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }

  .stats-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, #D4A574 50%, transparent 100%);
  }

  .stats-section::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, #D4A574 50%, transparent 100%);
  }

  .stats-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .eyebrow-gold {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #D4A574;
    margin-bottom: 24px;
  }

  .stats-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    color: #FFFFFF;
    margin: 0;
    text-wrap: balance;
  }

  .stats-title em {
    color: #D4A574;
    font-style: italic;
    font-weight: 400;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .stat-item {
    text-align: center;
    padding: 24px 16px;
    border-right: 1px solid rgba(212, 165, 116, 0.2);
    position: relative;
  }

  .stat-item:last-child { border-right: none; }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 700;
    color: #D4A574;
    line-height: 1;
    margin-bottom: 24px;
    font-variant-numeric: tabular-nums;
  }

  .stat-suffix { font-size: 0.6em; font-weight: 400; }
  .stat-suffix-small { font-size: 0.5em; }

  .stat-divider {
    width: 30px;
    height: 1px;
    background: #D4A574;
    margin: 0 auto 20px;
  }

  .stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #FFFFFF;
    margin-bottom: 4px;
  }

  .stat-sublabel {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .stat-item:nth-child(2) { border-right: none; }
    .stat-item:nth-child(1), .stat-item:nth-child(2) {
      border-bottom: 1px solid rgba(212, 165, 116, 0.2);
      padding-bottom: 40px;
    }
    .stat-item:nth-child(3), .stat-item:nth-child(4) { padding-top: 40px; }
  }
</style>
