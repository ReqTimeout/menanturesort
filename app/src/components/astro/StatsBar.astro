---
const stats = [
  { rangeStart: '74', rangeUnit: 'unit', label: 'Total Villa', sublabel: 'Seluruh Kawasan 3,5 Ha' },
  { rangeStart: '9–15', rangeUnit: 'jt/bln', label: 'Passive Income', sublabel: 'Setelah Operasional 20%' },
  { rangeStart: '15–30', rangeUnit: '% p.a.', label: 'Capital Gain', sublabel: 'Proyeksi 15 Tahun' },
  { rangeStart: '50+', rangeUnit: 'tahun', label: 'Track Record', sublabel: 'Sahid Hotels & Resorts' },
];
---
<section class="section section-cream relative overflow-hidden">
  <div class="absolute inset-0 pattern-grid opacity-40"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500 to-transparent"></div>

  <div class="container-tight relative">
    <div class="text-center mb-16">
      <span class="eyebrow">Angka yang Tidak Bohong</span>
      <h2 class="heading-title mt-4">
        Mengapa 58 Investor Sudah<br/><em>Memilih Menantu Resort</em>
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="font-display text-forest-500 mb-3" style="font-size: clamp(2.25rem, 4.5vw, 3.25rem); font-weight: 700; line-height: 1; letter-spacing: -0.025em;">
            {stat.rangeStart}<span class="text-gold-700 ml-1" style="font-size: 0.5em; font-weight: 500;">{stat.rangeUnit}</span>
          </div>
          <div class="h-px w-10 bg-gold-500 mx-auto mb-3"></div>
          <div class="font-display text-base text-forest-700 font-semibold mb-1">{stat.label}</div>
          <div class="text-sm text-ink-700">{stat.sublabel}</div>
        </div>
      ))}
    </div>
  </div>
</section>
