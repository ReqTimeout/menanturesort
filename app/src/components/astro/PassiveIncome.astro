---
import villaData from '../../data/villa.json';
import { formatShort } from '../../lib/utils';
---
<section class="section section-cream">
  <div class="container-tight">
    <div class="text-center mb-16">
      <span class="eyebrow">Simulasi Passive Income</span>
      <h2 class="heading-title mt-4">
        Bayangkan: <br/><em>Villa Anda Membayar</em><br/>Cicilannya Sendiri.
      </h2>
      <p class="text-body-lg text-ink-500 max-w-2xl mx-auto mt-6">
        Okupansi 50%, tarif Rp 2.2 jt/malam. Cicilan 15 tahun ke bank.
        Income yang masuk dari idle villa menutup cicilan, dengan surplus.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {villaData.types.map((villa) => {
        const cicilan = villa.cicilanBank;
        const income = villa.passiveIncome;
        const surplus = income - cicilan;
        const ratio = Math.min(100, (income / cicilan) * 100);
        return (
          <div class="card accent-line p-8 md:p-10">
            <div class="flex items-baseline justify-between mb-2">
              <h3 class="font-display text-xl text-forest-700">{villa.name}</h3>
              <span class="text-xs text-gold-700 font-mono">{((income/cicilan)*100).toFixed(0)}% cover</span>
            </div>
            <div class="text-sm text-ink-700 mb-8">{villa.bestFor}</div>

            <div class="space-y-5">
              <div>
                <div class="flex items-baseline justify-between mb-2">
                  <span class="text-xs text-ink-700 uppercase tracking-wider">Cicilan / Bulan</span>
                  <span class="font-mono text-sm text-ink-500">{formatShort(cicilan)}</span>
                </div>
                <div class="h-1 bg-cream-100 overflow-hidden">
                  <div class="h-full bg-ink-700" style={`width: ${(cicilan/cicilan)*100}%`}></div>
                </div>
              </div>

              <div>
                <div class="flex items-baseline justify-between mb-2">
                  <span class="text-xs text-ink-700 uppercase tracking-wider">Income / Bulan</span>
                  <span class="font-mono text-sm text-forest-500 font-semibold">{formatShort(income)}</span>
                </div>
                <div class="h-1 bg-cream-100 overflow-hidden">
                  <div class="h-full bg-forest-500" style={`width: ${ratio}%`}></div>
                </div>
              </div>

              <div class="pt-5 border-t border-cream-100">
                <div class="flex items-baseline justify-between">
                  <span class="text-xs text-ink-700 uppercase tracking-wider">Surplus / Bulan</span>
                  <span class="font-mono text-lg text-success font-bold">+{formatShort(surplus)}</span>
                </div>
                <div class="text-xs text-ink-700 mt-2">* Estimasi okupansi 50%, setelah operasional 20%.</div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
