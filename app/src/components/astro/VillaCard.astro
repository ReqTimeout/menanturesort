---
import villaData from '../../data/villa.json';
import { formatShort, waUrl } from '../../lib/utils';
import VillaArt from '../../lib/components/sections/VillaArt.svelte';
import siteData from '../../data/site.json';
import { ArrowRight, Bed, Bath, Maximize, Square, FileCheck, MessageCircle } from 'lucide-svelte';

const waLink = (id: string, msg: string) => waUrl(siteData.contact.whatsapp, msg, `villa_${id}`);
---
<section id="villa-types" class="section section-white">
  <div class="container-wide">
    <div class="text-center mb-20">
      <span class="eyebrow">Pilih Villa Anda</span>
      <h2 class="heading-title mt-4">
        3 Tipe Villa, <br/><em>Semua dengan SHM.</em>
      </h2>
      <p class="text-body-lg text-ink-500 max-w-2xl mx-auto mt-6">
        Dari entry-level untuk investor muda hingga flagship dengan sky deck panoramic.
        Semua dengan sertifikat Hak Milik atas nama pribadi.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {villaData.types.map((villa) => {
        const link = waLink(villa.id, `Halo, saya tertarik dengan ${villa.name}`);
        const surplus = villa.passiveIncome - villa.cicilanBank;
        return (
          <article class="card accent-line group">
            <div class="aspect-[4/3] overflow-hidden bg-forest-700">
              <VillaArt client:visible type={villa.id} class="w-full h-full transition-transform duration-700 group-hover:scale-105" />
            </div>

            <div class="p-8 md:p-10">
              {villa.bestValue && (
                <div class="mb-4">
                  <span class="badge badge-gold">⭐ Best Value</span>
                </div>
              )}

              <h3 class="font-display text-2xl md:text-3xl mb-2">{villa.name}</h3>
              <p class="font-quote italic text-ink-500 text-base mb-6">"{villa.tagline}"</p>

              <div class="font-mono text-2xl text-forest-500 mb-1">{villa.priceDisplay}</div>
              <div class="text-xs text-ink-700 mb-6">Booking fee Rp 10 jt (refundable 30 hari)</div>

              <div class="grid grid-cols-3 gap-2 mb-6 text-xs">
                <div class="flex items-center gap-1.5 text-ink-700">
                  <Bed size="14" class="text-forest-500" /> {villa.bedrooms} KT
                </div>
                <div class="flex items-center gap-1.5 text-ink-700">
                  <Bath size="14" class="text-forest-500" /> {villa.bathrooms} KM
                </div>
                <div class="flex items-center gap-1.5 text-ink-700">
                  <Maximize size="14" class="text-forest-500" /> {villa.lb} m²
                </div>
              </div>

              <div class="space-y-3 mb-8 pb-6 border-b border-cream-100">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-ink-500">Cicilan KPR</span>
                  <span class="font-mono font-semibold">{formatShort(villa.cicilanBank)}</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-ink-500">Passive Income</span>
                  <span class="font-mono font-semibold text-forest-500">{formatShort(villa.passiveIncome)}</span>
                </div>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-ink-500">Surplus / Bulan</span>
                  <span class="font-mono font-semibold text-success">+{formatShort(surplus)}</span>
                </div>
              </div>

              <div class="flex gap-3">
                <a href={`/villa/${villa.id}/`} class="btn btn-outline flex-1 text-xs">
                  Detail <ArrowRight size="14" />
                </a>
                <a href={link} target="_blank" rel="noopener" class="btn btn-whatsapp flex-1 text-xs">
                  <MessageCircle size="14" /> Chat
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
