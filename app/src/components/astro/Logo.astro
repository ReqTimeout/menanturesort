---
interface Props {
  variant?: 'full' | 'mark';
  className?: string;
}
const { variant = 'full', className = '' } = Astro.props;
---
{variant === 'full' ? (
  <a href="/" class={`flex items-center gap-sm group ${className}`}>
    <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center font-display font-bold text-xl text-primary-dark group-hover:scale-105 transition-transform">
      M
    </div>
    <div class="flex flex-col leading-tight">
      <span class="font-display font-semibold text-base text-primary">Menantu Resort</span>
      <span class="text-[10px] tracking-widest uppercase text-gray-500">Managed by Sahid</span>
    </div>
  </a>
) : (
  <a href="/" class={`inline-flex items-center justify-center w-10 h-10 rounded-full bg-secondary font-display font-bold text-xl text-primary-dark ${className}`}>
    M
  </a>
)}
