---
/**
 * SectionDivider — Premium gold ornament seam between sections
 *
 * Behavior:
 * - Transparent bg (blends with both sections above & below)
 * - Centered SVG ornament + gradient line
 * - Three variants: simple (dot) | ornate (5-diamond) | diamond (single rotated square)
 *
 * No background, no pattern — pure SVG ornament for seamless transition.
 */
interface Props {
  variant?: 'simple' | 'ornate' | 'diamond';
  class?: string;
}

const { variant = 'simple', class: className = '' } = Astro.props;
---

<div class={`w-full flex items-center justify-center gap-3 py-6 ${className}`}>
  {variant === 'simple' && (
    <>
      <span class="flex-1 max-w-[120px] h-px bg-gradient-to-r from-transparent to-gold-500/60"></span>
      <svg width="14" height="14" viewBox="0 0 14 14" class="text-gold-500 flex-shrink-0" fill="currentColor" aria-hidden="true">
        <circle cx="7" cy="7" r="3" />
      </svg>
      <span class="flex-1 max-w-[120px] h-px bg-gradient-to-l from-transparent to-gold-500/60"></span>
    </>
  )}

  {variant === 'ornate' && (
    <>
      <span class="flex-1 max-w-[180px] h-px bg-gradient-to-r from-transparent to-gold-500/60"></span>
      <svg width="80" height="14" viewBox="0 0 80 14" class="text-gold-500 flex-shrink-0" fill="none" stroke="currentColor" aria-hidden="true">
        <line x1="0" y1="7" x2="28" y2="7" stroke-width="0.8" />
        <circle cx="32" cy="7" r="1.8" fill="currentColor" stroke="none" />
        <path d="M 38 7 L 40 4 L 42 7 L 40 10 Z" fill="currentColor" stroke="none" />
        <circle cx="48" cy="7" r="1.8" fill="currentColor" stroke="none" />
        <line x1="52" y1="7" x2="80" y2="7" stroke-width="0.8" />
      </svg>
      <span class="flex-1 max-w-[180px] h-px bg-gradient-to-l from-transparent to-gold-500/60"></span>
    </>
  )}

  {variant === 'diamond' && (
    <>
      <span class="flex-1 max-w-[120px] h-px bg-gradient-to-r from-transparent to-gold-500/60"></span>
      <svg width="18" height="18" viewBox="0 0 18 18" class="text-gold-500 flex-shrink-0 rotate-45" fill="currentColor" aria-hidden="true">
        <rect x="5" y="5" width="8" height="8" />
      </svg>
      <svg width="10" height="10" viewBox="0 0 10 10" class="text-gold-500 flex-shrink-0 rotate-45" fill="currentColor" aria-hidden="true">
        <rect x="3" y="3" width="4" height="4" />
      </svg>
      <svg width="18" height="18" viewBox="0 0 18 18" class="text-gold-500 flex-shrink-0 rotate-45" fill="currentColor" aria-hidden="true">
        <rect x="5" y="5" width="8" height="8" />
      </svg>
      <span class="flex-1 max-w-[120px] h-px bg-gradient-to-l from-transparent to-gold-500/60"></span>
    </>
  )}
</div>
