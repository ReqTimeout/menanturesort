---
import Logo from './Logo.astro';
import siteData from '../../data/site.json';
import { waUrl } from '../../lib/utils';
import { Menu, X, MessageCircle } from 'lucide-svelte';

const navLinks = [
  { href: '/', label: 'Beranda' },
  { href: '/villa', label: 'Tipe Villa' },
  { href: '/investasi', label: 'Investasi' },
  { href: '/resort', label: 'Resort' },
  { href: '/lokasi', label: 'Lokasi' },
  { href: '/artikel', label: 'Artikel' },
  { href: '/kontak', label: 'Kontak' },
];

const currentPath = Astro.url.pathname;
const waLink = waUrl(siteData.contact.whatsapp, 'Halo, saya tertarik dengan Menantu Resort', 'navbar');
---
<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 backdrop-blur-md bg-cream-50/85 border-b border-cream-100/60">
  <div class="container-wide">
    <div class="flex items-center justify-between h-20">
      <Logo />

      <nav class="hidden lg:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`font-body text-sm font-medium transition-colors hover:text-gold-700 relative py-2 ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-gold-700'
                : 'text-forest-700'
            }`}
          >
            {link.label}
            {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
              <span class="absolute -bottom-0.5 left-0 right-0 h-px bg-gold-500"></span>
            )}
          </a>
        ))}
      </nav>

      <div class="hidden lg:flex items-center gap-3">
        <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm">
          <MessageCircle size="16" /> Chat
        </a>
      </div>

      <button id="mobile-toggle" class="lg:hidden text-forest-700 p-2" aria-label="Menu">
        <Menu size="24" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-cream-50 border-t border-cream-100">
    <div class="container-wide py-6 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block py-3 font-body font-medium ${
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-gold-700'
              : 'text-forest-700'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp w-full mt-4">
        <MessageCircle size="16" /> Chat WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
