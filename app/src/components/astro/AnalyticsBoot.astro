---
/**
 * AnalyticsBoot.astro — GA4 + Google Ads + Enhanced Conversions
 *
 * Features:
 * 1. gtag.js unified load (GA4 + Google Ads)
 * 2. gtag_report_conversion snippet for Google Ads conversion tracking
 * 3. Enhanced Conversions SHA-256 helpers (auto-hash user PII)
 * 4. Global WhatsApp click interceptor with 1.5s delayed redirect
 * 5. Auto-injects conversion data into every wa.me link
 *
 * Set env vars in .env or cPanel Node.js app:
 *   PUBLIC_GA4_ID=G-XXXXXXXXXX
 *   PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
 *   PUBLIC_GTM_ID=GTM-XXXXXXX (optional)
 *   PUBLIC_ADS_CONVERSION_LABEL=/<label> (e.g. /vK06CJ_ui78cEITUzvlD)
 */
const GA4_ID = import.meta.env.PUBLIC_GA4_ID || 'G-39JSBHZY3T';
const ADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID || 'AW-18240219652';
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || '';
const ADS_CONVERSION_LABEL = import.meta.env.PUBLIC_ADS_CONVERSION_LABEL || 'vK06CJ_ui78cEITUzvlD';
---

{GA4_ID && (
  <>
    <!-- Google tag (gtag.js) - GA4 + Google Ads unified -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
    <script is:inline define:vars={{ GA4_ID, ADS_ID, GTM_ID, ADS_CONVERSION_LABEL }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());

      // Configure GA4
      gtag('config', GA4_ID, {
        anonymize_ip: true,
        send_page_view: true,
        // Enhanced Conversions: auto-detect user data from forms
        enhanced_conversions: { gdpr_consent_enabled: false }
      });

      // Configure Google Ads
      if (ADS_ID) {
        gtag('config', ADS_ID, {
          allow_enhanced_conversions: true,
          send_page_view: true
        });
      }

      // ═══════════════════════════════════════════════════════════
      // GOOGLE ADS CONVERSION TRACKER
      // (Per snippet docs: https://support.google.com/tagmanager/answer/7545739)
      // ═══════════════════════════════════════════════════════════
      window.gtag_report_conversion = function(url) {
        var callback = function () {
          if (typeof(url) != 'undefined' && url) {
            window.location = url;
          }
        };
        // Fire conversion event to Google Ads
        gtag('event', 'conversion', {
          'send_to': ADS_ID + '/' + ADS_CONVERSION_LABEL,
          'value': 1.0,
          'currency': 'IDR',
          'event_callback': callback
        });
        // Fallback: if gtag fails to fire within 2s, redirect anyway
        setTimeout(function() {
          if (typeof(url) != 'undefined' && url && !window._mrRedirected) {
            window._mrRedirected = true;
            window.location = url;
          }
        }, 2000);
        return false;
      };

      // ═══════════════════════════════════════════════════════════
      // ENHANCED CONVERSIONS — SHA-256 hashing
      // ═══════════════════════════════════════════════════════════
      window.mrEnhancedConversions = {
        hashData: async function(data) {
          const encoder = new TextEncoder();
          const normalize = (str) => String(str || '').trim().toLowerCase().replace(/\s+/g, '');
          const hash = async (str) => {
            if (!str) return undefined;
            const normalized = normalize(str);
            if (!normalized) return undefined;
            const buffer = await crypto.subtle.digest('SHA-256', encoder.encode(normalized));
            return Array.from(new Uint8Array(buffer)).map(b => b.toString(16).padStart(2, '0')).join('');
          };
          return {
            email: await hash(data.email),
            phone_number: await hash(data.phone),
            first_name: await hash(data.firstName),
            last_name: await hash(data.lastName),
            address: data.address ? {
              street: await hash(data.address.street),
              city: await hash(data.address.city),
              region: await hash(data.address.region),
              postal_code: data.address.postal ? String(data.address.postal).replace(/\s/g, '') : undefined,
              country: data.address.country || 'ID'
            } : undefined
          };
        },
        trackConversion: async function(eventName, userData, conversionData) {
          const hashed = await this.hashData(userData);
          if (typeof window.gtag === 'function') {
            window.gtag('event', eventName, {
              ...conversionData,
              enhanced_conversions_data: hashed,
              send_to: ADS_ID || GA4_ID
            });
          }
        }
      };

      // ═══════════════════════════════════════════════════════════
      // SITE ANALYTICS HELPERS
      // ═══════════════════════════════════════════════════════════
      window.mrAnalytics = {
        trackEvent: function (name, params) {
          if (typeof window.gtag === 'function') {
            window.gtag('event', name, params || {});
          }
        },
        trackPageview: function (path) {
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'page_view', {
              page_path: path,
              page_title: document.title,
              send_to: GA4_ID
            });
          }
        },
        trackWhatsApp: function (source, label, conversionLabel) {
          if (typeof window.gtag === 'function') {
            // GA4 event
            window.gtag('event', 'whatsapp_click', {
              event_category: 'engagement',
              event_label: label || source,
              source: source,
              send_to: ADS_ID ? [GA4_ID, ADS_ID] : GA4_ID
            });
            // Google Ads conversion (if label provided)
            if (conversionLabel) {
              window.gtag('event', 'conversion', {
                send_to: ADS_ID + '/' + conversionLabel,
                value: 1.0,
                currency: 'IDR'
              });
            }
          }
        },
        trackLead: async function (formData) {
          await window.mrEnhancedConversions.trackConversion('generate_lead', formData, {
            event_category: 'lead',
            event_label: formData.leadType || 'general',
            value: formData.estimatedValue || 0,
            currency: 'IDR',
            send_to: ADS_ID || GA4_ID
          });
        }
      };

      // ═══════════════════════════════════════════════════════════
      // GLOBAL WHATSAPP CLICK INTERCEPTOR
      // Auto-tracks ALL wa.me clicks with 1.5s delay redirect
      // (so Google Ads conversion registers before navigation)
      // ═══════════════════════════════════════════════════════════
      document.addEventListener('click', function(e) {
        const link = e.target.closest && e.target.closest('a[href*="wa.me/"]');
        if (!link) return;
        const href = link.getAttribute('href');
        if (!href) return;
        // Don't intercept if it's a mailto/tel or already has data attribute (manually handled)
        if (link.dataset.tracked === 'true') return;
        e.preventDefault();
        // Identify source
        const source = link.dataset.track || link.getAttribute('data-source') || 'unknown';
        const label = link.getAttribute('aria-label') || link.textContent?.trim().slice(0, 50) || 'wa_click';
        // Fire events
        if (typeof window.mrAnalytics !== 'undefined') {
          window.mrAnalytics.trackWhatsApp(source, label, ADS_CONVERSION_LABEL);
        }
        // Fire the Google Ads conversion with callback
        if (typeof window.gtag_report_conversion === 'function') {
          // Mark as tracked
          link.dataset.tracked = 'true';
          // Use the conversion snippet, which will redirect after firing
          window.gtag_report_conversion(href);
        } else {
          // Fallback: 1.5s delay then redirect
          setTimeout(function() { window.location = href; }, 1500);
        }
      }, true);
    </script>
  </>
)}
