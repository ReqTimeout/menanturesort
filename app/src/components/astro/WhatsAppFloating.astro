---
import siteData from '../../data/site.json';
import { waUrl } from '../../lib/format';

const waLink = waUrl(siteData.contact.whatsapp, 'Halo, saya tertarik dengan Menantu Resort. Bisa info lebih lanjut?', 'floating_button');
---
<a
  href={waLink}
  target="_blank"
  rel="noopener"
  id="wa-floating"
  class="fixed bottom-6 right-6 z-30 w-14 h-14 md:w-16 md:h-16 rounded-full bg-whatsapp text-white flex items-center justify-center shadow-xl animate-pulse-wa hover:scale-110 transition-transform"
  aria-label="Chat WhatsApp"
  data-track="whatsapp_click"
  data-source="floating_button"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.4-.1-.6.1-.2.3-.7.9-.8 1-.1.2-.3.2-.5.1-.3-.1-1.2-.5-2.3-1.5-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.4.1-.6.1-.1.3-.3.4-.5.1-.1.2-.3.2-.4.1-.2 0-.3 0-.5-.1-.1-.6-1.5-.8-2.1-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4 0 1.4 1 2.8 1.2 3 .1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.8.1.5-.1 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.2-.5-.4zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
  </svg>
</a>

<style>
  /* Tooltip on hover */
  #wa-floating::before {
    content: 'Chat Sales Expert';
    position: absolute;
    right: 100%;
    margin-right: 12px;
    background: #0D1B14;
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(8px);
    transition: all 0.3s;
    pointer-events: none;
  }
  #wa-floating:hover::before {
    opacity: 1;
    transform: translateX(0);
  }
</style>
