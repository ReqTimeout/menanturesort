---
import HeroParallax from '../svelte/HeroParallax.svelte';
import siteData from '../../data/site.json';
import { waUrl } from '../../lib/utils';
import { ArrowRight, Check } from 'lucide-svelte';

const waLink = waUrl(siteData.contact.whatsapp, 'Halo, saya tertarik dengan Menantu Resort. Bisa info lebih lanjut?', 'homepage_hero');
---
<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Photo background with parallax -->
  <HeroParallax client:load />

  <!-- Dark gradient overlay for text readability (only on photo) -->
  <div class="absolute inset-0 bg-gradient-to-r from-forest-900/85 via-forest-900/65 to-forest-900/40 z-[1]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-forest-900/60 to-transparent z-[1]"></div>

  <div class="relative z-10 container-wide w-full pt-32 pb-20 md:pt-40 md:pb-32 text-cream-50">
    <div class="max-w-3xl">
      <div class="flex items-center gap-4 mb-8 animate-fade-in-up opacity-0" style="animation-delay: 0.1s">
        <span class="h-px w-12 bg-gold-500"></span>
        <span class="eyebrow text-gold-500">Investasi Villa Bandung · SHM · Dikelola Sahid</span>
      </div>

      <h1 class="font-display text-cream-50 mb-8 text-balance" style="font-size: clamp(2.5rem, 6vw, 4.75rem); line-height: 1.0; letter-spacing: -0.025em; font-weight: 700;">
        <span class="block">Miliki Villa Impian</span>
        <span class="block">di Bandung.</span>
        <span class="block italic text-gold-500 mt-2" style="font-weight: 500;">Bayar Rp 9 Juta / Bulan.</span>
      </h1>

      <p class="font-body text-lg md:text-xl text-cream-50/85 leading-relaxed max-w-xl mb-10 animate-fade-in-up opacity-0" style="animation-delay: 0.5s">
        Tidak perlu repot cari tamu. Tidak perlu pusing maintenance.
        <span class="text-gold-500 font-semibold">Sahid Hotel & Resort (50+ tahun)</span> yang urus semuanya.
        Anda terima passive income setiap bulan.
      </p>

      <div class="flex flex-wrap gap-4 mb-16 animate-fade-in-up opacity-0" style="animation-delay: 0.7s">
        <a href="#villa-types" class="btn btn-secondary btn-lg">
          Lihat Skema Investasi
          <ArrowRight size="18" strokeWidth="2.5" />
        </a>
        <a href={waLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
          Chat WhatsApp
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-cream-50/85 animate-fade-in-up opacity-0" style="animation-delay: 0.9s">
        <div class="flex items-center gap-2"><Check size="16" class="text-gold-500" /> 74 Unit, 58 Terjual</div>
        <div class="hidden md:block h-4 w-px bg-cream-50/30"></div>
        <div class="flex items-center gap-2"><Check size="16" class="text-gold-500" /> SHM, Bukan Sewa</div>
        <div class="hidden md:block h-4 w-px bg-cream-50/30"></div>
        <div class="flex items-center gap-2"><Check size="16" class="text-gold-500" /> Sahid 50+ Tahun</div>
        <div class="hidden md:block h-4 w-px bg-cream-50/30"></div>
        <div class="flex items-center gap-2"><Check size="16" class="text-gold-500" /> Cicilan 9-15 Juta</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-3 text-xs text-cream-50/60 uppercase tracking-widest">
    <span>Scroll untuk jelajahi</span>
    <div class="h-12 w-px bg-gradient-to-b from-gold-500 to-transparent"></div>
  </div>
</section>
