---
import siteData from '../../data/site.json';
import { Instagram, Phone, Mail, MapPin, Building2 } from 'lucide-svelte';

// Bank logos (inline SVG path untuk hemat bundle — no external image)
const banks = [
  { name: 'BNI', color: '#F26522' },
  { name: 'BCA', color: '#003D7A' },
  { name: 'BSI', color: '#00A39A' },
];
---
<footer class="section-tight section-cream border-t border-cream-100">
  <div class="container-wide">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-16 mb-12">
      <div class="md:col-span-4">
        <div class="font-display text-2xl text-forest-700 mb-3">Menantu Resort</div>
        <p class="text-sm text-ink-700 mb-6 max-w-sm">{siteData.tagline}</p>
        <div class="flex items-center gap-3 text-forest-700">
          <a href={`https://instagram.com/${siteData.social.instagram.replace('@','')}`} target="_blank" rel="noopener" class="w-9 h-9 border border-cream-100 flex items-center justify-center hover:border-gold-500 hover:text-gold-700 transition-colors">
            <Instagram size={16} />
          </a>
          <a href={`tel:${siteData.contact.whatsapp}`} class="w-9 h-9 border border-cream-100 flex items-center justify-center hover:border-gold-500 hover:text-gold-700 transition-colors">
            <Phone size={16} />
          </a>
          <a href={`mailto:${siteData.contact.email}`} class="w-9 h-9 border border-cream-100 flex items-center justify-center hover:border-gold-500 hover:text-gold-700 transition-colors">
            <Mail size={16} />
          </a>
        </div>
      </div>

      <div class="md:col-span-3">
        <span class="eyebrow text-forest-700 mb-4 block">Halaman</span>
        <ul class="space-y-2 text-sm">
          <li><a href="/villa" class="text-ink-500 hover:text-gold-700 transition-colors">Tipe Villa</a></li>
          <li><a href="/investasi" class="text-ink-500 hover:text-gold-700 transition-colors">Investasi</a></li>
          <li><a href="/lokasi" class="text-ink-500 hover:text-gold-700 transition-colors">Lokasi</a></li>
          <li><a href="/progress" class="text-ink-500 hover:text-gold-700 transition-colors">Progress</a></li>
          <li><a href="/resort" class="text-ink-500 hover:text-gold-700 transition-colors">Resort</a></li>
          <li><a href="/artikel" class="text-ink-500 hover:text-gold-700 transition-colors">Artikel</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <span class="eyebrow text-forest-700 mb-4 block">Kontak</span>
        <ul class="space-y-2 text-sm text-ink-500">
          <li class="flex items-start gap-2">
            <MapPin size={14} class="text-gold-700 mt-1 flex-shrink-0" />
            <span class="leading-relaxed">{siteData.contact.address}</span>
          </li>
          <li class="flex items-center gap-2">
            <Phone size={14} class="text-gold-700 flex-shrink-0" />
            <span class="font-mono">{siteData.contact.whatsappDisplay}</span>
          </li>
          <li class="flex items-center gap-2">
            <Mail size={14} class="text-gold-700 flex-shrink-0" />
            <span>{siteData.contact.email}</span>
          </li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <span class="eyebrow text-forest-700 mb-4 block">Legal</span>
        <ul class="space-y-2 text-sm">
          <li><a href="/faq" class="text-ink-500 hover:text-gold-700 transition-colors">FAQ</a></li>
          <li><a href="/syarat-dan-ketentuan" class="text-ink-500 hover:text-gold-700 transition-colors">Syarat</a></li>
          <li><a href="/kebijakan-privasi" class="text-ink-500 hover:text-gold-700 transition-colors">Privasi</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-cream-100">
      <!-- Bank partner logos — trust signal (replace anti-fraud) -->
      <div class="flex flex-wrap items-center gap-6 mb-6">
        <span class="text-xs uppercase tracking-widest text-ink-mute">Rekening Resmi</span>
        <div class="flex items-center gap-4">
          {banks.map((b) => (
            <div class="flex items-center gap-2 px-3 py-1.5 bg-white border border-cream-100">
              <Building2 size={14} style={`color: ${b.color}`} />
              <span class="font-mono text-sm font-semibold" style={`color: ${b.color}`}>{b.name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-4 text-xs text-ink-700">
        <p>© {new Date().getFullYear()} Menantu Resort managed by Sahid. All rights reserved.</p>
        <p>
          Developed by
          <a href="https://beriklan.co.id" target="_blank" rel="noopener noreferrer" class="text-forest-700 font-semibold hover:text-gold-700 transition-colors underline-offset-4 hover:underline">
            beriklan.co.id
          </a>
          <span class="text-ink-mute">· {siteData.developer.brand}</span>
        </p>
      </div>
    </div>
  </div>
</footer>
