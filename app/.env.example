# ===================================================================
# Menantu Resort — Production Environment Variables
# ===================================================================
# Copy file ini ke .env dan isi value yang sebenarnya.
# Variables dengan prefix PUBLIC_ akan di-bundle ke client-side.

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
PUBLIC_GA4_ID=

# Google Ads Conversion ID (format: AW-XXXXXXXXXX)
# Untuk track konversi WhatsApp click sebagai conversion
PUBLIC_GOOGLE_ADS_ID=

# Meta (Facebook) Pixel ID (format: 123456789012345)
# Untuk track lead generation & retargeting
PUBLIC_META_PIXEL_ID=

# WhatsApp Business Phone (optional, default dari site.json)
# Format: 6281234567890 (62 + nomor tanpa + atau 0 di depan)
PUBLIC_WA_PHONE=
