# Menantu Resort — Environment Variables Template
# Copy file ini ke .env (untuk local dev) atau set di cPanel Node.js App

# === Public site ===
SITE_URL=https://menantu-resort.com
SITE_NAME="Menantu Resort"
NODE_ENV=production

# === Optional: Analytics (set jika pakai) ===
# PUBLIC_GA4_ID=G-XXXXXXXXXX
# PUBLIC_GTM_ID=GTM-XXXXXXX
# PUBLIC_META_PIXEL_ID=000000000000000

# === Optional: Form backend (set jika pakai Formspree/Web3Forms) ===
# FORMSPREE_ID=xyzabc123
# WEB3FORMS_KEY=xxxx-yyyy-zzzz

# === Optional: WhatsApp Business API (advanced) ===
# WA_PHONE_NUMBER_ID=000000000000000
# WA_ACCESS_TOKEN=xxxxx
