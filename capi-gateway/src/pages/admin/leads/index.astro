---
/**
 * /admin/leads — Lead list with filters
 */
const { SITE_URL } = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const status = url.searchParams.get('status') || '';
const search = url.searchParams.get('search') || '';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leads — Menantu Resort CRM</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-50 text-stone-900 min-h-screen">
  <header class="bg-gradient-to-r from-emerald-900 to-emerald-800 text-white sticky top-0 z-10 shadow-md">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold">Menantu Resort CRM</h1>
        <p class="text-xs text-emerald-200 font-mono uppercase tracking-wider">Leads</p>
      </div>
      <nav class="flex items-center gap-6 text-sm">
        <a href="/admin" class="text-emerald-200 hover:text-white">Dashboard</a>
        <a href="/admin/leads" class="text-white font-semibold">Leads</a>
        <button id="logout" class="text-emerald-200 hover:text-white text-xs uppercase tracking-wider">Logout</button>
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-8">
    <div id="auth-prompt" class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-sm border border-stone-200">
      <h2 class="text-lg font-bold mb-2">🔐 Masukkan Admin API Key</h2>
      <input id="api-key" type="password" placeholder="admin-api-key-xxx..." class="w-full px-3 py-2 border border-stone-300 rounded font-mono text-sm mb-3" />
      <button id="auth-submit" class="w-full bg-emerald-900 text-white py-2.5 rounded font-semibold text-sm">Masuk</button>
      <p id="auth-error" class="text-red-600 text-xs mt-2 hidden"></p>
    </div>

    <div id="content" class="hidden">
      <div class="flex items-center justify-between mb-6 gap-4 flex-wrap">
        <h2 class="text-2xl font-bold">Leads</h2>
        <div class="flex items-center gap-2 flex-wrap">
          <input id="search" type="text" placeholder="Cari nama / phone / email..." value={search} class="px-3 py-2 border border-stone-300 rounded text-sm w-64" />
          <select id="status-filter" class="px-3 py-2 border border-stone-300 rounded text-sm">
            <option value="">All Status</option>
            <option value="new">New</option>
            <option value="contacted">Contacted</option>
            <option value="qualified">Qualified</option>
            <option value="tour_scheduled">Tour Scheduled</option>
            <option value="won">Won</option>
            <option value="lost">Lost</option>
            <option value="abandoned">Abandoned</option>
          </select>
        </div>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-stone-200 overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-stone-50 text-xs uppercase tracking-wider text-stone-600 border-b border-stone-200">
            <tr>
              <th class="text-left px-4 py-3">Name</th>
              <th class="text-left px-4 py-3">Phone</th>
              <th class="text-left px-4 py-3">Villa</th>
              <th class="text-left px-4 py-3">Source</th>
              <th class="text-left px-4 py-3">Status</th>
              <th class="text-left px-4 py-3">Created</th>
            </tr>
          </thead>
          <tbody id="leads-tbody"></tbody>
        </table>
        <div id="leads-empty" class="p-8 text-center text-stone-500 hidden">Belum ada leads.</div>
      </div>
    </div>
  </main>

  <script is:inline define:vars={{ initialStatus: status, initialSearch: search }}>
    const API = location.origin;
    let apiKey = localStorage.getItem('mr_admin_key') || '';

    function getHeaders() {
      return { 'Authorization': 'Bearer ' + apiKey, 'Content-Type': 'application/json' };
    }
    async function api(path) {
      const res = await fetch(API + path, { headers: getHeaders() });
      if (res.status === 401) {
        document.getElementById('auth-prompt').classList.remove('hidden');
        document.getElementById('content').classList.add('hidden');
        throw new Error('Unauthorized');
      }
      return res;
    }

    function escapeHtml(s) {
      const div = document.createElement('div');
      div.textContent = s || '';
      return div.innerHTML;
    }

    document.getElementById('auth-submit').addEventListener('click', () => {
      apiKey = document.getElementById('api-key').value.trim();
      if (!apiKey) return;
      localStorage.setItem('mr_admin_key', apiKey);
      show();
    });
    document.getElementById('api-key').addEventListener('keypress', (e) => { if (e.key === 'Enter') document.getElementById('auth-submit').click(); });
    document.getElementById('logout').addEventListener('click', () => { localStorage.removeItem('mr_admin_key'); location.reload(); });

    if (initialStatus) document.getElementById('status-filter').value = initialStatus;

    async function show() {
      document.getElementById('auth-prompt').classList.add('hidden');
      document.getElementById('content').classList.remove('hidden');
      await load();
    }

    async function load() {
      const status = document.getElementById('status-filter').value;
      const search = document.getElementById('search').value.trim();
      const params = new URLSearchParams();
      if (status) params.set('status', status);
      if (search) params.set('search', search);
      params.set('limit', '100');

      const res = await api('/api/leads?' + params);
      const data = await res.json();
      const rows = data.leads || [];

      const tbody = document.getElementById('leads-tbody');
      const empty = document.getElementById('leads-empty');

      if (rows.length === 0) {
        tbody.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');

      const statusColor = { new: 'amber', contacted: 'blue', qualified: 'violet', tour_scheduled: 'sky', won: 'emerald', lost: 'rose', abandoned: 'stone' };

      tbody.innerHTML = rows.map(l => `
        <tr class="border-b border-stone-100 hover:bg-stone-50 cursor-pointer" onclick="location.href='/admin/leads/${l.id}'">
          <td class="px-4 py-3 font-semibold">${escapeHtml(l.name || '(no name)')}</td>
          <td class="px-4 py-3 font-mono text-xs">${escapeHtml(l.phone || '-')}</td>
          <td class="px-4 py-3"><span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider bg-stone-100 text-stone-700">${escapeHtml(l.villa_pref || '-')}</span></td>
          <td class="px-4 py-3 font-mono text-xs text-stone-600">${escapeHtml(l.source || '-')}</td>
          <td class="px-4 py-3"><span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider bg-${statusColor[l.status] || 'stone'}-100 text-${statusColor[l.status] || 'stone'}-800">${l.status}</span></td>
          <td class="px-4 py-3 text-xs text-stone-500 font-mono">${formatTime(l.created_at)}</td>
        </tr>
      `).join('');
    }

    function formatTime(unix) {
      const d = new Date(unix * 1000);
      return d.toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: '2-digit' }) + ' ' + d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    }

    document.getElementById('status-filter').addEventListener('change', load);
    let searchTimer;
    document.getElementById('search').addEventListener('input', () => { clearTimeout(searchTimer); searchTimer = setTimeout(load, 300); });

    if (apiKey) api('/api/leads').then(r => r.ok && show()).catch(() => {});
  </script>
</body>
</html>
